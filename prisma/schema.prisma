// LifeNavigator Comprehensive Database Schema for Azure PostgreSQL
// Version: 1.0.0 - Production Ready
// Includes: Core models, Goals system, Risk Assessment, and all domain models

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//=====================
// AUTHENTICATION & USERS
//=====================

model User {
  id                    String                  @id @default(cuid())
  email                 String                  @unique
  name                  String?
  password              String?
  emailVerified         DateTime?
  image                 String?
  role                  String                  @default("user")
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  setupCompleted        Boolean                 @default(false)
  lastLogin             DateTime?
  isActive              Boolean                 @default(true)
  failedLoginAttempts   Int                     @default(0)
  lockedUntil           DateTime?
  mfaEnabled            Boolean                 @default(false)
  mfaSecret             String?
  recoveryCodes         String?                 // JSON array of hashed recovery codes

  // Relations
  accounts              Account[]
  sessions              Session[]
  goals                 Goal[]
  riskAssessments       RiskAssessment[]
  financialAccounts     FinancialAccount[]
  financialTransactions Transaction[]
  financialAssets       Asset[]
  financialGoals        FinancialGoal[]
  healthRecords         HealthRecord[]
  healthMetrics         HealthMetric[]
  educationRecords      EducationRecord[]
  educationCourses      EducationCourse[]
  careerProfiles        CareerProfile[]
  careerApplications    JobApplication[]
  documents             Document[]
  notifications         Notification[]
  preferences           UserPreference?
  profile               UserProfile?
  securityAuditLogs     SecurityAuditLog[]
  securityTokens        SecurityToken[]
  revokedTokens         RevokedToken[]
  userDevices           UserDevice[]
  integrations          UserIntegration[]
  benefitRankings       BenefitRanking[]
  familyMembers         FamilyMember[]
  pets                  Pet[]
  familyAppointments    FamilyAppointment[]
  plaidItems            PlaidItem[]
  calendarConnections   CalendarConnection[]
  socialNetworkConnections SocialNetworkConnection[]
  networkValueInsights  NetworkValueInsight[]

  @@index([email])
  @@index([createdAt])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model RevokedToken {
  id        String   @id @default(cuid())
  jti       String   @unique
  userId    String
  revokedAt DateTime @default(now())
  expiresAt DateTime
  reason    String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([jti])
  @@map("revoked_tokens")
}

model SecurityAuditLog {
  id           String   @id @default(cuid())
  userId       String
  action       String   // CREATE, READ, UPDATE, DELETE per HIPAA
  resourceType String   // Type of resource accessed
  resourceId   String   // ID of resource accessed
  eventType    String?  // Legacy field
  ipAddress    String?
  userAgent    String?
  data         Json?
  metadata     String?  @db.Text
  timestamp    DateTime @default(now())
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action])
  @@index([resourceType])
  @@index([timestamp])
  @@index([createdAt])
  @@map("security_audit_logs")
}

model SecurityToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique // Hashed token
  purpose   String   // password_reset, email_verification, etc.
  expiresAt DateTime
  used      Boolean  @default(false)
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("security_tokens")
}

model UserDevice {
  id        String   @id @default(cuid())
  userId    String
  deviceId  String   @unique
  name      String?
  type      String?  // mobile, desktop, tablet
  os        String?
  browser   String?
  ipAddress String?
  userAgent String?
  lastSeen  DateTime @default(now())
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([deviceId])
  @@map("user_devices")
}

model BenefitRanking {
  id        String   @id @default(cuid())
  userId    String
  domain    String   // financial, career, health, education, lifestyle
  tagId     String   // Reference to benefit tag ID
  rank      Int      // 1 is highest priority
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId, domain, tagId])
  @@index([userId, domain])
  @@index([rank])
  @@map("benefit_rankings")
}

//=====================
// GOALS SYSTEM
//=====================

model Goal {
  id              String           @id @default(cuid())
  userId          String
  title           String
  description     String?
  category        GoalCategory     @relation(fields: [categoryId], references: [id])
  categoryId      String
  targetDate      DateTime?
  targetValue     Float?           // For measurable goals
  currentValue    Float?           @default(0)
  unit            String?          // e.g., "dollars", "pounds", "hours"
  priority        String           @default("medium") // low, medium, high, critical
  status          String           @default("active") // draft, active, completed, paused, abandoned
  isSmartGoal     Boolean          @default(false)
  specific        String?          // SMART goal components
  measurable      String?
  achievable      String?
  relevant        String?
  timeBound       String?
  completedAt     DateTime?
  progress        Float            @default(0) // 0-100 percentage
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  
  // Relations
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  milestones      GoalMilestone[]
  benefits        GoalBenefit[]
  updates         GoalUpdate[]
  reminders       GoalReminder[]
  dependencies    GoalDependency[] @relation("DependentGoal")
  dependents      GoalDependency[] @relation("PrerequisiteGoal")
  
  @@index([userId])
  @@index([categoryId])
  @@index([status])
  @@index([targetDate])
  @@map("goals")
}

model GoalCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  icon        String?
  color       String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  
  // Relations
  goals       Goal[]
  
  @@map("goal_categories")
}

model GoalMilestone {
  id           String    @id @default(cuid())
  goalId       String
  title        String
  description  String?
  targetDate   DateTime?
  targetValue  Float?
  isCompleted  Boolean   @default(false)
  completedAt  DateTime?
  order        Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  
  // Relations
  goal         Goal      @relation(fields: [goalId], references: [id], onDelete: Cascade)
  
  @@index([goalId])
  @@map("goal_milestones")
}

model GoalBenefit {
  id          String   @id @default(cuid())
  goalId      String
  benefitType String   // health, wealth, relationships, personal_growth, career, happiness
  description String
  impact      String   @default("medium") // low, medium, high
  createdAt   DateTime @default(now())
  
  // Relations
  goal        Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)
  
  @@index([goalId])
  @@index([benefitType])
  @@map("goal_benefits")
}

model GoalUpdate {
  id          String   @id @default(cuid())
  goalId      String
  updateType  String   // progress, note, milestone_completed, status_change
  content     String?
  oldValue    Float?
  newValue    Float?
  createdAt   DateTime @default(now())
  
  // Relations
  goal        Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)
  
  @@index([goalId])
  @@index([createdAt])
  @@map("goal_updates")
}

model GoalReminder {
  id           String   @id @default(cuid())
  goalId       String
  reminderType String   // deadline, milestone, check_in
  message      String
  sendAt       DateTime
  isSent       Boolean  @default(false)
  sentAt       DateTime?
  createdAt    DateTime @default(now())
  
  // Relations
  goal         Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)
  
  @@index([goalId])
  @@index([sendAt])
  @@map("goal_reminders")
}

model GoalDependency {
  id              String   @id @default(cuid())
  dependentId     String   // The goal that depends on another
  prerequisiteId  String   // The goal that must be completed first
  createdAt       DateTime @default(now())
  
  // Relations
  dependent       Goal     @relation("DependentGoal", fields: [dependentId], references: [id], onDelete: Cascade)
  prerequisite    Goal     @relation("PrerequisiteGoal", fields: [prerequisiteId], references: [id], onDelete: Cascade)
  
  @@unique([dependentId, prerequisiteId])
  @@map("goal_dependencies")
}

//=====================
// RISK ASSESSMENT
//=====================

model RiskAssessment {
  id                String                 @id @default(cuid())
  userId            String
  assessmentType    String                 // initial, periodic, goal_specific
  status            String                 @default("in_progress") // in_progress, completed, expired
  completedAt       DateTime?
  expiresAt         DateTime?              // When reassessment is needed
  overallRiskScore  Float?                 // 0-100
  riskLevel         String?                // low, medium, high, critical
  theta             Float?                 // Calculated theta value from conversation
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  
  // Relations
  user              User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers           AssessmentAnswer[]
  categoryScores    RiskCategoryScore[]
  recommendations   RiskRecommendation[]
  
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("risk_assessments")
}

model AssessmentQuestion {
  id              String              @id @default(cuid())
  category        String              // financial, health, career, personal, family
  subcategory     String?
  question        String
  questionType    String              // multiple_choice, scale, yes_no, text
  options         Json?               // For multiple choice questions
  minValue        Int?                // For scale questions
  maxValue        Int?                // For scale questions
  weight          Float               @default(1.0) // Importance in scoring
  order           Int                 @default(0)
  isActive        Boolean             @default(true)
  requiredFor     String[]            // User segments this applies to
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  
  // Relations
  answers         AssessmentAnswer[]
  
  @@index([category])
  @@index([isActive])
  @@map("assessment_questions")
}

model AssessmentAnswer {
  id              String              @id @default(cuid())
  assessmentId    String
  questionId      String
  answerValue     String?             // Text or selected option
  answerScore     Float?              // Numerical value for scales
  riskImpact      Float?              // How this answer affects risk score
  confidence      Float?              // User's confidence in their answer (0-1)
  notes           String?
  createdAt       DateTime            @default(now())
  
  // Relations
  assessment      RiskAssessment      @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  question        AssessmentQuestion  @relation(fields: [questionId], references: [id])
  
  @@unique([assessmentId, questionId])
  @@index([assessmentId])
  @@map("assessment_answers")
}

model RiskCategoryScore {
  id              String           @id @default(cuid())
  assessmentId    String
  category        String           // financial, health, career, personal, family
  score           Float            // 0-100
  riskLevel       String           // low, medium, high, critical
  factors         Json?            // Key factors contributing to this score
  createdAt       DateTime         @default(now())
  
  // Relations
  assessment      RiskAssessment   @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  
  @@unique([assessmentId, category])
  @@index([assessmentId])
  @@map("risk_category_scores")
}

model RiskRecommendation {
  id              String           @id @default(cuid())
  assessmentId    String
  category        String
  priority        String           // immediate, high, medium, low
  title           String
  description     String
  actionItems     Json?            // Array of specific actions
  resources       Json?            // Links, tools, etc.
  estimatedImpact String?          // Expected improvement
  createdAt       DateTime         @default(now())
  
  // Relations
  assessment      RiskAssessment   @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  
  @@index([assessmentId])
  @@index([priority])
  @@map("risk_recommendations")
}

//=====================
// USER PREFERENCES
//=====================

model UserPreference {
  id                   String  @id @default(cuid())
  userId               String  @unique
  theme                String  @default("system") // light, dark, system
  currency             String  @default("USD")
  language             String  @default("en")
  timezone             String  @default("UTC")
  emailNotifications   Boolean @default(true)
  pushNotifications    Boolean @default(true)
  smsNotifications     Boolean @default(false)
  newsletterSubscribed Boolean @default(true)
  dateFormat           String  @default("MM/DD/YYYY")
  timeFormat           String  @default("12h") // 12h, 24h
  firstDayOfWeek       Int     @default(0) // 0=Sunday, 1=Monday
  dashboardLayout      Json?   // Custom dashboard configuration
  user                 User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

model UserProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Demographics
  dateOfBirth    DateTime?
  gender         String?   // male, female, non-binary, prefer not to say
  phoneNumber    String?
  address        String?
  city           String?
  state          String?
  zipCode        String?
  country        String?   @default("US")
  maritalStatus  String?   // single, married, divorced, widowed, partnered
  dependents     Int?      @default(0)

  // Professional Information
  occupation        String?
  employer          String?
  industry          String?
  yearsOfExperience Int?
  educationLevel    String?  // high_school, associates, bachelors, masters, doctorate, other
  skills            String?  @db.Text  // JSON array of skills
  linkedInUrl       String?
  websiteUrl        String?

  // Financial Information
  incomeRange       String?  // <25k, 25k-50k, 50k-75k, 75k-100k, 100k-150k, 150k-200k, 200k+
  netWorthRange     String?  // <0, 0-50k, 50k-100k, 100k-250k, 250k-500k, 500k-1m, 1m+
  financialGoals    String?  @db.Text  // JSON array
  riskTolerance     String?  // conservative, moderate, aggressive
  retirementAge     Int?

  // Health & Wellness
  healthStatus      String?  // excellent, good, fair, poor
  fitnessLevel      String?  // sedentary, lightly_active, moderately_active, very_active, extremely_active
  fitnessGoals      String?  @db.Text  // JSON array
  dietaryPreferences String? // none, vegetarian, vegan, pescatarian, keto, paleo, other
  medicalConditions  String? @db.Text  // JSON array (optional, encrypted)

  // Lifestyle & Preferences
  bio               String?  @db.Text
  interests         String?  @db.Text  // JSON array
  hobbies           String?  @db.Text  // JSON array
  values            String?  @db.Text  // JSON array
  lifeGoals         String?  @db.Text  // JSON array

  // Profile Completion
  profileCompletion Int      @default(0)  // 0-100 percentage

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_profiles")
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String    // info, success, warning, error, reminder
  category  String?   // goals, finance, health, etc.
  priority  String    @default("normal") // low, normal, high, urgent
  read      Boolean   @default(false)
  actionUrl String?   // Link to relevant page
  metadata  Json?     // Additional data
  createdAt DateTime  @default(now())
  readAt    DateTime?
  expiresAt DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([read])
  @@index([createdAt])
  @@map("notifications")
}

//=====================
// FINANCIAL MODELS
//=====================

// Plaid Integration Models
model PlaidItem {
  id               String           @id @default(cuid())
  userId           String
  itemId           String           // Plaid item ID
  accessToken      String           @db.Text // Encrypted access token
  institutionId    String
  institutionName  String
  status           String           @default("active") // active, error, needs_update
  lastSyncedAt     DateTime         @default(now())
  error            String?          @db.Text
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  // Relations
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  accounts         PlaidAccount[]
  transactions     PlaidTransaction[]

  @@unique([userId, itemId])
  @@index([userId])
  @@index([status])
  @@map("plaid_items")
}

model PlaidAccount {
  id               String            @id @default(cuid())
  plaidItemId      String
  accountId        String            // Plaid account ID
  name             String
  officialName     String?
  type             String            // depository, credit, loan, investment
  subtype          String?           // checking, savings, credit card, etc.
  mask             String?           // Last 4 digits
  currentBalance   Float?
  availableBalance Float?
  limit            Float?            // Credit limit
  currency         String            @default("USD")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  // Relations
  plaidItem        PlaidItem         @relation(fields: [plaidItemId], references: [id], onDelete: Cascade)
  transactions     PlaidTransaction[]

  @@unique([plaidItemId, accountId])
  @@index([plaidItemId])
  @@map("plaid_accounts")
}

model PlaidTransaction {
  id                  String       @id @default(cuid())
  plaidItemId         String
  plaidAccountId      String
  transactionId       String       // Plaid transaction ID
  amount              Float
  date                DateTime
  name                String
  merchantName        String?
  category            String[]     // Array of category strings
  pending             Boolean      @default(false)
  paymentChannel      String?      // online, in store, etc.
  transactionType     String?      // place, digital, etc.
  isoCurrencyCode     String       @default("USD")
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  // Relations
  plaidItem           PlaidItem    @relation(fields: [plaidItemId], references: [id], onDelete: Cascade)
  plaidAccount        PlaidAccount @relation(fields: [plaidAccountId], references: [id], onDelete: Cascade)

  @@unique([plaidItemId, transactionId])
  @@index([plaidItemId])
  @@index([plaidAccountId])
  @@index([date])
  @@map("plaid_transactions")
}

model FinancialAccount {
  id                String        @id @default(cuid())
  userId            String
  name              String
  type              String        // checking, savings, investment, credit, loan, crypto
  subtype           String?       // specific account subtype
  institution       String
  accountNumber     String?       // encrypted
  routingNumber     String?       // encrypted
  balance           Float
  availableBalance  Float?
  creditLimit       Float?        // for credit accounts
  interestRate      Float?        // for loans/savings
  currency          String        @default("USD")
  isActive          Boolean       @default(true)
  isPrimary         Boolean       @default(false)
  lastSynced        DateTime      @default(now())
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  notes             String?
  integrationId     String?       // ID for third-party integration
  
  // Relations
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions      Transaction[]
  
  @@unique([userId, name])
  @@index([userId])
  @@index([type])
  @@map("financial_accounts")
}

model Transaction {
  id                String           @id @default(cuid())
  userId            String
  accountId         String
  amount            Float
  currency          String           @default("USD")
  description       String
  category          String
  subcategory       String?
  date              DateTime
  type              String           // income, expense, transfer, investment
  status            String           @default("completed") // pending, completed, failed, cancelled
  isRecurring       Boolean          @default(false)
  recurringId       String?          // Link to recurring transaction pattern
  merchantName      String?
  merchantCategory  String?
  reference         String?          // External reference number
  notes             String?
  tags              String[]
  locationLat       Float?
  locationLong      Float?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  
  // Relations
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  account           FinancialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([accountId])
  @@index([date])
  @@index([category])
  @@map("transactions")
}

model Asset {
  id                String   @id @default(cuid())
  userId            String
  name              String
  type              String   // real_estate, vehicle, cryptocurrency, collectible, business, other
  subtype           String?
  value             Float
  currency          String   @default("USD")
  purchaseDate      DateTime?
  purchasePrice     Float?
  currentValue      Float
  lastValuationDate DateTime @default(now())
  location          String?
  description       String?
  notes             String?
  documents         Json?    // Related document IDs
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  // Relations
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([type])
  @@map("assets")
}

model FinancialGoal {
  id            String   @id @default(cuid())
  userId        String
  name          String
  description   String?
  type          String   // savings, debt_payoff, investment, retirement, purchase
  targetAmount  Float
  currentAmount Float    @default(0)
  currency      String   @default("USD")
  targetDate    DateTime?
  priority      String   @default("medium") // low, medium, high, critical
  status        String   @default("active") // draft, active, completed, paused, abandoned
  category      String   // retirement, education, home, emergency, vacation, other
  strategy      Json?    // Saving/investment strategy details
  milestones    Json?    // Array of milestone objects
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  completedAt   DateTime?
  
  // Relations
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([status])
  @@map("financial_goals")
}

//=====================
// HEALTH MODELS
//=====================

model HealthRecord {
  id                String   @id @default(cuid())
  userId            String
  type              String   // medical_visit, procedure, diagnosis, medication, immunization, lab_result
  category          String?  // preventive, emergency, routine, specialist
  providerName      String?
  providerType      String?  // doctor, specialist, hospital, clinic
  facilityName      String?
  date              DateTime
  title             String
  description       String
  diagnosis         String?
  treatment         String?
  prescription      Json?    // Medication details
  followUpDate      DateTime?
  attachmentUrls    String[] // URLs to secure documents
  notes             String?
  isConfidential    Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  // Relations
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([date])
  @@index([type])
  @@map("health_records")
}

model HealthMetric {
  id          String   @id @default(cuid())
  userId      String
  type        String   // weight, blood_pressure, heart_rate, blood_sugar, cholesterol, sleep, steps
  value       Float
  unit        String
  systolic    Float?   // For blood pressure
  diastolic   Float?   // For blood pressure
  date        DateTime
  time        String?  // Time of day for certain metrics
  notes       String?
  source      String   @default("manual") // manual, device, integration
  deviceId    String?
  deviceName  String?
  isAbnormal  Boolean  @default(false)
  createdAt   DateTime @default(now())
  
  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([date])
  @@index([type])
  @@map("health_metrics")
}

//=====================
// EDUCATION MODELS
//=====================

model EducationRecord {
  id           String    @id @default(cuid())
  userId       String
  type         String    // degree, certification, course, training, workshop
  institution  String
  degree       String?
  major        String?
  minor        String?
  gpa          Float?
  credits      Float?
  startDate    DateTime
  endDate      DateTime?
  status       String    @default("in_progress") // in_progress, completed, on_hold, dropped
  isVerified   Boolean   @default(false)
  certificateUrl String?
  transcriptUrl String?
  description  String?
  achievements Json?     // Honors, awards, etc.
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  
  // Relations
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([status])
  @@map("education_records")
}

model EducationCourse {
  id                String    @id @default(cuid())
  userId            String
  title             String
  provider          String
  platform          String?   // Coursera, Udemy, etc.
  instructorName    String?
  url               String?
  courseCode        String?
  credits           Float?
  startDate         DateTime?
  endDate           DateTime?
  expectedEndDate   DateTime?
  status            String    @default("enrolled") // enrolled, in_progress, completed, dropped
  progress          Float     @default(0) // 0 to 100
  grade             String?
  certificateEarned Boolean   @default(false)
  certificateUrl    String?
  certificateDate   DateTime?
  skills            String[]  // Skills gained
  notes             String?
  cost              Float?
  isPaid            Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  // Relations
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([status])
  @@map("education_courses")
}

//=====================
// CAREER MODELS
//=====================

model CareerProfile {
  id                String    @id @default(cuid())
  userId            String
  title             String?
  company           String?
  industry          String?
  yearsExperience   Int?
  currentSalary     Float?
  desiredSalary     Float?
  skills            String[]
  certifications    String[]
  languages         Json?     // Languages and proficiency levels
  bio               String?
  resumeUrl         String?
  resumeUpdatedAt   DateTime?
  linkedInUrl       String?
  githubUrl         String?
  portfolioUrl      String?
  websiteUrl        String?
  availableFrom     DateTime?
  preferredLocation String?
  remotePreference  String?   // remote, hybrid, onsite
  jobSearchStatus   String    @default("not_looking") // active, passive, not_looking
  visibility        String    @default("private") // public, connections, private
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  // Relations
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@map("career_profiles")
}

model JobApplication {
  id              String    @id @default(cuid())
  userId          String
  companyName     String
  position        String
  department      String?
  jobUrl          String?
  jobDescription  String?
  applicationDate DateTime
  source          String?   // where you found the job
  status          String    // applied, screening, interviewing, offer, rejected, accepted, withdrawn
  stage           String?   // phone_screen, technical, onsite, final
  salary          Float?
  salaryMin       Float?
  salaryMax       Float?
  location        String?
  workType        String?   // remote, hybrid, onsite
  contactName     String?
  contactEmail    String?
  contactPhone    String?
  notes           String?
  interviewDates  Json?     // Array of interview dates and types
  offerDate       DateTime?
  offerDeadline   DateTime?
  startDate       DateTime?
  rejectionReason String?
  followUpDate    DateTime?
  documents       Json?     // Resume version, cover letter, etc.
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Relations
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([status])
  @@index([applicationDate])
  @@map("job_applications")
}

//=====================
// DOCUMENT MODELS
//=====================

model Document {
  id            String   @id @default(cuid())
  userId        String
  title         String
  description   String?
  category      String   // financial, health, education, career, legal, personal, tax
  subcategory   String?
  fileUrl       String   // URL to the encrypted document
  thumbnailUrl  String?
  fileName      String
  fileType      String
  mimeType      String?
  fileSize      Int
  fileHash      String?  // SHA-256 hash for integrity
  tags          String[]
  isEncrypted   Boolean  @default(true)
  encryptionKey String?  // Reference to encryption key (not the key itself)
  isArchived    Boolean  @default(false)
  expiresAt     DateTime?
  metadata      Json?    // Additional file metadata
  ocrText       String?  // Extracted text for searchability
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Relations
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([category])
  @@index([createdAt])
  @@map("documents")
}

//=====================
// INTEGRATION MODELS
//=====================

model UserIntegration {
  id              String    @id @default(cuid())
  userId          String
  provider        String    // plaid, mint, fitbit, google_fit, linkedin, etc.
  providerUserId  String?
  accessToken     String?   @db.Text // Encrypted
  refreshToken    String?   @db.Text // Encrypted
  tokenExpiresAt  DateTime?
  scopes          String[]
  status          String    @default("active") // active, revoked, expired, error
  lastSyncedAt    DateTime?
  lastError       String?
  syncFrequency   String?   // realtime, daily, weekly, manual
  settings        Json?     // Provider-specific settings
  metadata        Json?     // Provider-specific metadata
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Relations
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId, provider])
  @@index([provider])
  @@index([status])
  @@map("user_integrations")
}

//=====================
// FAMILY MODELS
//=====================

model FamilyMember {
  id              String              @id @default(cuid())
  userId          String
  firstName       String
  lastName        String?
  nickname        String?
  relationship    String              // spouse, partner, child, parent, sibling, grandparent, grandchild, other
  dateOfBirth     DateTime?
  gender          String?             // male, female, non-binary, prefer not to say
  email           String?
  phoneNumber     String?
  address         String?
  city            String?
  state           String?
  zipCode         String?
  country         String?

  // Medical Information (optional)
  bloodType       String?
  allergies       String?             @db.Text
  medications     String?             @db.Text
  medicalNotes    String?             @db.Text
  emergencyContact String?
  emergencyPhone  String?

  // Additional Information
  occupation      String?
  employer        String?
  school          String?
  grade           String?
  photoUrl        String?
  notes           String?             @db.Text
  favoriteThings  Json?               // Favorite colors, foods, activities, etc.

  // Settings
  isDependent     Boolean             @default(false)
  isEmergencyContact Boolean          @default(false)
  isPrimary       Boolean             @default(false) // Primary contact/spouse
  isActive        Boolean             @default(true)

  // Metadata
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  // Relations
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointments    FamilyAppointment[]

  @@index([userId])
  @@index([relationship])
  @@index([isActive])
  @@map("family_members")
}

model Pet {
  id              String              @id @default(cuid())
  userId          String
  name            String
  species         String              // dog, cat, bird, fish, reptile, rabbit, hamster, other
  breed           String?
  color           String?
  gender          String?             // male, female, unknown
  dateOfBirth     DateTime?
  adoptionDate    DateTime?
  age             Int?                // Age in years
  weight          Float?              // Weight in pounds/kg
  weightUnit      String?             @default("lbs")

  // Medical Information
  microchipNumber String?
  vetName         String?
  vetPhone        String?
  vetEmail        String?
  vetAddress      String?
  allergies       String?             @db.Text
  medications     String?             @db.Text
  medicalConditions String?           @db.Text
  medicalNotes    String?             @db.Text

  // Care Information
  feedingSchedule Json?               // Times and food types
  exerciseNeeds   String?
  specialNeeds    String?             @db.Text
  behaviorNotes   String?             @db.Text

  // Additional Information
  photoUrl        String?
  photos          String[]            // Array of photo URLs
  insuranceProvider String?
  insurancePolicyNumber String?
  notes           String?             @db.Text

  // Settings
  isActive        Boolean             @default(true)
  isServiceAnimal Boolean             @default(false)

  // Metadata
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  // Relations
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointments    FamilyAppointment[]

  @@index([userId])
  @@index([species])
  @@index([isActive])
  @@map("pets")
}

model FamilyAppointment {
  id              String        @id @default(cuid())
  userId          String
  familyMemberId  String?       // Reference to family member
  petId           String?       // Reference to pet

  // Appointment Details
  title           String
  description     String?       @db.Text
  type            String        // medical, dental, vet, school, activity, other
  category        String?       // checkup, emergency, routine, follow_up, consultation

  // Location Information
  providerName    String?
  facilityName    String?
  address         String?
  city            String?
  state           String?
  zipCode         String?
  phone           String?

  // Timing
  appointmentDate DateTime
  startTime       String?       // HH:MM format
  endTime         String?       // HH:MM format
  duration        Int?          // Duration in minutes
  timezone        String?       @default("UTC")

  // Status & Reminders
  status          String        @default("scheduled") // scheduled, confirmed, completed, cancelled, no_show
  reminderSent    Boolean       @default(false)
  reminderTime    DateTime?     // When to send reminder

  // Additional Information
  reason          String?
  notes           String?       @db.Text
  cost            Float?
  isPaid          Boolean       @default(false)
  insuranceClaimed Boolean      @default(false)
  documents       String[]      // URLs to related documents

  // Recurrence
  isRecurring     Boolean       @default(false)
  recurrenceRule  String?       // RRULE format for recurring appointments
  recurrenceId    String?       // Link to recurring appointment series

  // Metadata
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  completedAt     DateTime?

  // Relations
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  familyMember    FamilyMember? @relation(fields: [familyMemberId], references: [id], onDelete: Cascade)
  pet             Pet?          @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([familyMemberId])
  @@index([petId])
  @@index([appointmentDate])
  @@index([status])
  @@index([type])
  @@map("family_appointments")
}
//=====================
// CALENDAR INTEGRATION
//=====================

model CalendarConnection {
  id               String          @id @default(cuid())
  userId           String
  provider         String          // google, microsoft, apple
  email            String
  accessToken      String          @db.Text
  refreshToken     String?         @db.Text
  expiresAt        DateTime?
  scope            String?
  isPrimary        Boolean         @default(false)
  status           String          @default("active") // active, error, expired
  lastSyncedAt     DateTime        @default(now())
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  // Relations
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  events           CalendarEvent[]

  @@unique([userId, provider, email])
  @@index([userId])
  @@index([provider])
  @@map("calendar_connections")
}

model CalendarEvent {
  id                  String             @id @default(cuid())
  calendarConnectionId String
  eventId             String             // External event ID
  title               String
  description         String?            @db.Text
  location            String?
  startTime           DateTime
  endTime             DateTime
  isAllDay            Boolean            @default(false)
  status              String             @default("confirmed") // confirmed, tentative, cancelled
  attendees           String?            @db.Text // JSON array
  recurrence          String?            // Recurrence rule
  reminderMinutes     Int?
  meetingLink         String?
  calendarName        String?
  color               String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  // Relations
  calendarConnection  CalendarConnection @relation(fields: [calendarConnectionId], references: [id], onDelete: Cascade)

  @@unique([calendarConnectionId, eventId])
  @@index([calendarConnectionId])
  @@index([startTime])
  @@index([status])
  @@map("calendar_events")
}

//=====================
// SOCIAL NETWORK INTEGRATION
//=====================

model SocialNetworkConnection {
  id               String               @id @default(cuid())
  userId           String
  platform         String               // linkedin, instagram, twitter, tiktok
  username         String
  displayName      String?
  profileUrl       String?
  profileImageUrl  String?
  accessToken      String?              @db.Text
  refreshToken     String?              @db.Text
  expiresAt        DateTime?
  status           String               @default("active") // active, error, expired
  lastSyncedAt     DateTime             @default(now())
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  // Relations
  user             User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  metrics          SocialNetworkMetric[]
  followers        SocialNetworkFollower[]

  @@unique([userId, platform, username])
  @@index([userId])
  @@index([platform])
  @@map("social_network_connections")
}

model SocialNetworkMetric {
  id                     String                  @id @default(cuid())
  socialNetworkConnectionId String
  date                   DateTime                @default(now())
  followersCount         Int                     @default(0)
  followingCount         Int                     @default(0)
  postsCount             Int                     @default(0)
  engagementRate         Float?                  // Percentage
  impressions            Int?
  reach                  Int?
  profileViews           Int?
  linkClicks             Int?
  estimatedValue         Float?                  // Calculated network value in USD
  createdAt              DateTime                @default(now())

  // Relations
  socialNetworkConnection SocialNetworkConnection @relation(fields: [socialNetworkConnectionId], references: [id], onDelete: Cascade)

  @@index([socialNetworkConnectionId])
  @@index([date])
  @@map("social_network_metrics")
}

model SocialNetworkFollower {
  id                     String                  @id @default(cuid())
  socialNetworkConnectionId String
  followerId             String                  // External follower ID
  username               String
  displayName            String?
  profileUrl             String?
  followerCount          Int?                    // Their follower count
  verifiedStatus         Boolean                 @default(false)
  influenceScore         Float?                  // Calculated influence 0-100
  industry               String?
  location               String?
  bio                    String?                 @db.Text
  engagementRate         Float?
  lastInteraction        DateTime?
  addedAt                DateTime                @default(now())
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt

  // Relations
  socialNetworkConnection SocialNetworkConnection @relation(fields: [socialNetworkConnectionId], references: [id], onDelete: Cascade)

  @@unique([socialNetworkConnectionId, followerId])
  @@index([socialNetworkConnectionId])
  @@index([influenceScore])
  @@map("social_network_followers")
}

//=====================
// NETWORK VALUE INSIGHTS
//=====================

model NetworkValueInsight {
  id               String   @id @default(cuid())
  userId           String
  platform         String   // linkedin, instagram, twitter, tiktok, overall
  insightType      String   // growth_rate, engagement_trend, high_value_connections, monetization_potential
  title            String
  description      String   @db.Text
  value            Float?   // Quantified value if applicable
  score            Int?     // Score 0-100
  recommendations  String?  @db.Text // JSON array of recommendations
  dataPoints       String?  @db.Text // JSON data supporting the insight
  generatedAt      DateTime @default(now())
  validUntil       DateTime?
  createdAt        DateTime @default(now())

  // Relations
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([platform])
  @@index([generatedAt])
  @@map("network_value_insights")
}
