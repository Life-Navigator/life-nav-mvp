@prefix ln: <https://ln.life/ontology#> .
@prefix schema: <https://schema.org/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .

# ============================================================================
# Education Domain - Credentials, Degrees, Courses, Certifications
# ============================================================================

# Core Education Classes
ln:EducationRecord a owl:Class ;
    rdfs:subClassOf ln:LNEntity ;
    rdfs:label "Education Record"@en ;
    rdfs:comment "Formal education history (degree, diploma, certificate)"@en .

ln:Degree a owl:Class ;
    rdfs:subClassOf ln:EducationRecord ;
    rdfs:label "Degree"@en ;
    rdfs:comment "Academic degree from a university or college"@en .

ln:AssociateDegree a owl:Class ;
    rdfs:subClassOf ln:Degree ;
    rdfs:label "Associate Degree"@en .

ln:BachelorDegree a owl:Class ;
    rdfs:subClassOf ln:Degree ;
    rdfs:label "Bachelor's Degree"@en .

ln:MasterDegree a owl:Class ;
    rdfs:subClassOf ln:Degree ;
    rdfs:label "Master's Degree"@en .

ln:DoctorateDegree a owl:Class ;
    rdfs:subClassOf ln:Degree ;
    rdfs:label "Doctorate Degree"@en ;
    rdfs:comment "PhD, EdD, MD, JD, etc."@en .

ln:ProfessionalDegree a owl:Class ;
    rdfs:subClassOf ln:Degree ;
    rdfs:label "Professional Degree"@en ;
    rdfs:comment "JD, MD, MBA, etc."@en .

ln:Diploma a owl:Class ;
    rdfs:subClassOf ln:EducationRecord ;
    rdfs:label "Diploma"@en ;
    rdfs:comment "High school diploma or equivalent"@en .

# Course Classes
ln:Course a owl:Class ;
    rdfs:subClassOf ln:LNEntity ;
    rdfs:label "Course"@en ;
    rdfs:comment "Educational course (online or in-person)"@en .

ln:OnlineCourse a owl:Class ;
    rdfs:subClassOf ln:Course ;
    rdfs:label "Online Course"@en .

ln:MOOC a owl:Class ;
    rdfs:subClassOf ln:OnlineCourse ;
    rdfs:label "MOOC"@en ;
    rdfs:comment "Massive Open Online Course"@en .

ln:InPersonCourse a owl:Class ;
    rdfs:subClassOf ln:Course ;
    rdfs:label "In-Person Course"@en .

ln:Workshop a owl:Class ;
    rdfs:subClassOf ln:Course ;
    rdfs:label "Workshop"@en ;
    rdfs:comment "Short-term intensive training"@en .

ln:Bootcamp a owl:Class ;
    rdfs:subClassOf ln:Course ;
    rdfs:label "Bootcamp"@en ;
    rdfs:comment "Intensive coding/skills bootcamp"@en .

# Professional Certification
ln:ProfessionalCertification a owl:Class ;
    rdfs:subClassOf ln:LNEntity ;
    rdfs:label "Professional Certification"@en ;
    rdfs:comment "Industry certification (different from course completion)"@en .

ln:TechCertification a owl:Class ;
    rdfs:subClassOf ln:ProfessionalCertification ;
    rdfs:label "Tech Certification"@en ;
    rdfs:comment "AWS, Google Cloud, Azure, etc."@en .

ln:ProjectManagementCertification a owl:Class ;
    rdfs:subClassOf ln:ProfessionalCertification ;
    rdfs:label "Project Management Certification"@en ;
    rdfs:comment "PMP, Scrum Master, etc."@en .

ln:FinancialCertification a owl:Class ;
    rdfs:subClassOf ln:ProfessionalCertification ;
    rdfs:label "Financial Certification"@en ;
    rdfs:comment "CFA, CFP, CPA, etc."@en .

ln:License a owl:Class ;
    rdfs:subClassOf ln:ProfessionalCertification ;
    rdfs:label "License"@en ;
    rdfs:comment "Professional license (medical, legal, etc.)"@en .

# Learning Progress Classes
ln:Enrollment a owl:Class ;
    rdfs:subClassOf ln:LNEntity ;
    rdfs:label "Enrollment"@en ;
    rdfs:comment "Active enrollment in a course or program"@en .

ln:CourseCompletion a owl:Class ;
    rdfs:subClassOf ln:LNEntity ;
    rdfs:label "Course Completion"@en ;
    rdfs:comment "Record of course completion"@en .

ln:Transcript a owl:Class ;
    rdfs:subClassOf ln:LNEntity ;
    rdfs:label "Transcript"@en ;
    rdfs:comment "Academic transcript with grades"@en .

# Degree Properties
ln:degreeType a owl:DatatypeProperty ;
    rdfs:domain ln:Degree ;
    rdfs:range xsd:string ;
    rdfs:label "degree type"@en ;
    rdfs:comment "BS, BA, MS, MA, MBA, PhD, MD, JD, etc."@en .

ln:majorField a owl:DatatypeProperty ;
    rdfs:domain ln:Degree ;
    rdfs:range xsd:string ;
    rdfs:label "major field"@en ;
    rdfs:comment "Field of study (Computer Science, Business, etc.)"@en .

ln:minorField a owl:DatatypeProperty ;
    rdfs:domain ln:Degree ;
    rdfs:range xsd:string ;
    rdfs:label "minor field"@en .

ln:concentration a owl:DatatypeProperty ;
    rdfs:domain ln:Degree ;
    rdfs:range xsd:string ;
    rdfs:label "concentration"@en ;
    rdfs:comment "Specialization within major"@en .

ln:gpa a owl:DatatypeProperty ;
    rdfs:domain ln:Degree ;
    rdfs:range xsd:decimal ;
    rdfs:label "GPA"@en ;
    rdfs:comment "Grade point average (0.0-4.0 scale)"@en .

ln:graduationDate a owl:DatatypeProperty ;
    rdfs:domain ln:Degree ;
    rdfs:range xsd:date ;
    rdfs:label "graduation date"@en .

ln:honors a owl:DatatypeProperty ;
    rdfs:domain ln:Degree ;
    rdfs:range xsd:string ;
    rdfs:label "honors"@en ;
    rdfs:comment "Summa Cum Laude, Magna Cum Laude, Cum Laude, etc."@en .

ln:thesis a owl:DatatypeProperty ;
    rdfs:domain ln:Degree ;
    rdfs:range xsd:string ;
    rdfs:label "thesis"@en ;
    rdfs:comment "Thesis or dissertation title"@en .

ln:advisor a owl:DatatypeProperty ;
    rdfs:domain ln:Degree ;
    rdfs:range xsd:string ;
    rdfs:label "advisor"@en ;
    rdfs:comment "Thesis advisor or doctoral supervisor"@en .

# Education Record Properties
ln:institutionName a owl:DatatypeProperty ;
    rdfs:domain ln:EducationRecord ;
    rdfs:range xsd:string ;
    rdfs:label "institution name"@en .

ln:educationStartDate a owl:DatatypeProperty ;
    rdfs:domain ln:EducationRecord ;
    rdfs:range xsd:date ;
    rdfs:label "education start date"@en .

ln:educationEndDate a owl:DatatypeProperty ;
    rdfs:domain ln:EducationRecord ;
    rdfs:range xsd:date ;
    rdfs:label "education end date"@en .

ln:isCurrentEducation a owl:DatatypeProperty ;
    rdfs:domain ln:EducationRecord ;
    rdfs:range xsd:boolean ;
    rdfs:label "is current education"@en .

ln:educationLocation a owl:DatatypeProperty ;
    rdfs:domain ln:EducationRecord ;
    rdfs:range xsd:string ;
    rdfs:label "education location"@en .

ln:credentialUrl a owl:DatatypeProperty ;
    rdfs:domain ln:EducationRecord ;
    rdfs:range xsd:string ;
    rdfs:label "credential URL"@en ;
    rdfs:comment "Link to digital credential or diploma"@en .

# Course Properties
ln:courseName a owl:DatatypeProperty ;
    rdfs:domain ln:Course ;
    rdfs:range xsd:string ;
    rdfs:label "course name"@en .

ln:courseCode a owl:DatatypeProperty ;
    rdfs:domain ln:Course ;
    rdfs:range xsd:string ;
    rdfs:label "course code"@en ;
    rdfs:comment "Course identifier (CS101, MATH202, etc.)"@en .

ln:courseDescription a owl:DatatypeProperty ;
    rdfs:domain ln:Course ;
    rdfs:range xsd:string ;
    rdfs:label "course description"@en .

ln:courseUrl a owl:DatatypeProperty ;
    rdfs:domain ln:Course ;
    rdfs:range xsd:string ;
    rdfs:label "course URL"@en .

ln:courseProvider a owl:DatatypeProperty ;
    rdfs:domain ln:Course ;
    rdfs:range xsd:string ;
    rdfs:label "course provider"@en ;
    rdfs:comment "Coursera, Udemy, edX, university, etc."@en .

ln:instructor a owl:DatatypeProperty ;
    rdfs:domain ln:Course ;
    rdfs:range xsd:string ;
    rdfs:label "instructor"@en .

ln:courseDuration a owl:DatatypeProperty ;
    rdfs:domain ln:Course ;
    rdfs:range xsd:integer ;
    rdfs:label "course duration"@en ;
    rdfs:comment "Duration in hours"@en .

ln:courseLevel a owl:DatatypeProperty ;
    rdfs:domain ln:Course ;
    rdfs:range xsd:string ;
    rdfs:label "course level"@en ;
    rdfs:comment "BEGINNER, INTERMEDIATE, ADVANCED, EXPERT"@en .

ln:courseTopic a owl:DatatypeProperty ;
    rdfs:domain ln:Course ;
    rdfs:range xsd:string ;
    rdfs:label "course topic"@en ;
    rdfs:comment "Subject area or topic"@en .

ln:courseLanguage a owl:DatatypeProperty ;
    rdfs:domain ln:Course ;
    rdfs:range xsd:string ;
    rdfs:label "course language"@en .

ln:credits a owl:DatatypeProperty ;
    rdfs:domain ln:Course ;
    rdfs:range xsd:decimal ;
    rdfs:label "credits"@en ;
    rdfs:comment "Academic credit hours"@en .

ln:hasCertificate a owl:DatatypeProperty ;
    rdfs:domain ln:Course ;
    rdfs:range xsd:boolean ;
    rdfs:label "has certificate"@en ;
    rdfs:comment "Whether completion certificate is offered"@en .

# Certification Properties
ln:certificationName a owl:DatatypeProperty ;
    rdfs:domain ln:ProfessionalCertification ;
    rdfs:range xsd:string ;
    rdfs:label "certification name"@en .

ln:certificationIssuer a owl:DatatypeProperty ;
    rdfs:domain ln:ProfessionalCertification ;
    rdfs:range xsd:string ;
    rdfs:label "certification issuer"@en ;
    rdfs:comment "AWS, Microsoft, PMI, etc."@en .

ln:issueDate a owl:DatatypeProperty ;
    rdfs:domain ln:ProfessionalCertification ;
    rdfs:range xsd:date ;
    rdfs:label "issue date"@en .

ln:expirationDate a owl:DatatypeProperty ;
    rdfs:domain ln:ProfessionalCertification ;
    rdfs:range xsd:date ;
    rdfs:label "expiration date"@en ;
    rdfs:comment "Null if certification doesn't expire"@en .

ln:isActive a owl:DatatypeProperty ;
    rdfs:domain ln:ProfessionalCertification ;
    rdfs:range xsd:boolean ;
    rdfs:label "is active"@en ;
    rdfs:comment "Whether certification is currently valid"@en .

ln:certificationId a owl:DatatypeProperty ;
    rdfs:domain ln:ProfessionalCertification ;
    rdfs:range xsd:string ;
    rdfs:label "certification ID"@en ;
    rdfs:comment "Unique credential identifier"@en .

ln:verificationUrl a owl:DatatypeProperty ;
    rdfs:domain ln:ProfessionalCertification ;
    rdfs:range xsd:string ;
    rdfs:label "verification URL"@en ;
    rdfs:comment "URL to verify credential"@en .

ln:certificationLevel a owl:DatatypeProperty ;
    rdfs:domain ln:ProfessionalCertification ;
    rdfs:range xsd:string ;
    rdfs:label "certification level"@en ;
    rdfs:comment "ASSOCIATE, PROFESSIONAL, EXPERT, SPECIALIST"@en .

ln:renewalRequired a owl:DatatypeProperty ;
    rdfs:domain ln:ProfessionalCertification ;
    rdfs:range xsd:boolean ;
    rdfs:label "renewal required"@en .

ln:renewalPeriod a owl:DatatypeProperty ;
    rdfs:domain ln:ProfessionalCertification ;
    rdfs:range xsd:integer ;
    rdfs:label "renewal period"@en ;
    rdfs:comment "Renewal period in months"@en .

# Enrollment Properties
ln:enrollmentDate a owl:DatatypeProperty ;
    rdfs:domain ln:Enrollment ;
    rdfs:range xsd:date ;
    rdfs:label "enrollment date"@en .

ln:enrollmentStatus a owl:DatatypeProperty ;
    rdfs:domain ln:Enrollment ;
    rdfs:range xsd:string ;
    rdfs:label "enrollment status"@en ;
    rdfs:comment "ENROLLED, IN_PROGRESS, COMPLETED, DROPPED, DEFERRED"@en .

ln:progressPercentage a owl:DatatypeProperty ;
    rdfs:domain ln:Enrollment ;
    rdfs:range xsd:decimal ;
    rdfs:label "progress percentage"@en ;
    rdfs:comment "0.0 to 100.0"@en .

ln:expectedCompletionDate a owl:DatatypeProperty ;
    rdfs:domain ln:Enrollment ;
    rdfs:range xsd:date ;
    rdfs:label "expected completion date"@en .

ln:studyHoursPerWeek a owl:DatatypeProperty ;
    rdfs:domain ln:Enrollment ;
    rdfs:range xsd:integer ;
    rdfs:label "study hours per week"@en .

# Course Completion Properties
ln:completionDate a owl:DatatypeProperty ;
    rdfs:domain ln:CourseCompletion ;
    rdfs:range xsd:date ;
    rdfs:label "completion date"@en .

ln:finalGrade a owl:DatatypeProperty ;
    rdfs:domain ln:CourseCompletion ;
    rdfs:range xsd:string ;
    rdfs:label "final grade"@en ;
    rdfs:comment "A, B+, 95%, Pass, etc."@en .

ln:gradePoints a owl:DatatypeProperty ;
    rdfs:domain ln:CourseCompletion ;
    rdfs:range xsd:decimal ;
    rdfs:label "grade points"@en ;
    rdfs:comment "Grade on 0.0-4.0 scale"@en .

ln:certificateUrl a owl:DatatypeProperty ;
    rdfs:domain ln:CourseCompletion ;
    rdfs:range xsd:string ;
    rdfs:label "certificate URL"@en ;
    rdfs:comment "Link to completion certificate"@en .

ln:certificateIssued a owl:DatatypeProperty ;
    rdfs:domain ln:CourseCompletion ;
    rdfs:range xsd:boolean ;
    rdfs:label "certificate issued"@en .

ln:passed a owl:DatatypeProperty ;
    rdfs:domain ln:CourseCompletion ;
    rdfs:range xsd:boolean ;
    rdfs:label "passed"@en .

ln:honorsMention a owl:DatatypeProperty ;
    rdfs:domain ln:CourseCompletion ;
    rdfs:range xsd:string ;
    rdfs:label "honors mention"@en ;
    rdfs:comment "With distinction, etc."@en .

# Transcript Properties
ln:transcriptUrl a owl:DatatypeProperty ;
    rdfs:domain ln:Transcript ;
    rdfs:range xsd:string ;
    rdfs:label "transcript URL"@en .

ln:overallGpa a owl:DatatypeProperty ;
    rdfs:domain ln:Transcript ;
    rdfs:range xsd:decimal ;
    rdfs:label "overall GPA"@en .

ln:totalCredits a owl:DatatypeProperty ;
    rdfs:domain ln:Transcript ;
    rdfs:range xsd:decimal ;
    rdfs:label "total credits"@en .

ln:isOfficial a owl:DatatypeProperty ;
    rdfs:domain ln:Transcript ;
    rdfs:range xsd:boolean ;
    rdfs:label "is official"@en .

# Relationships - Person to Education Records
ln:hasEducation a owl:ObjectProperty ;
    rdfs:domain ln:Person ;
    rdfs:range ln:EducationRecord ;
    rdfs:label "has education"@en ;
    owl:inverseOf ln:educationOf .

ln:educationOf a owl:ObjectProperty ;
    rdfs:domain ln:EducationRecord ;
    rdfs:range ln:Person ;
    rdfs:label "education of"@en ;
    owl:inverseOf ln:hasEducation .

# Relationships - Person to Enrollments
ln:enrolledIn a owl:ObjectProperty ;
    rdfs:domain ln:Person ;
    rdfs:range ln:Enrollment ;
    rdfs:label "enrolled in"@en ;
    owl:inverseOf ln:enrollmentBy .

ln:enrollmentBy a owl:ObjectProperty ;
    rdfs:domain ln:Enrollment ;
    rdfs:range ln:Person ;
    rdfs:label "enrollment by"@en ;
    owl:inverseOf ln:enrolledIn .

# Relationships - Enrollment to Course
ln:enrollmentFor a owl:ObjectProperty ;
    rdfs:domain ln:Enrollment ;
    rdfs:range ln:Course ;
    rdfs:label "enrollment for"@en .

# Relationships - Person to Certifications
ln:hasCertification a owl:ObjectProperty ;
    rdfs:domain ln:Person ;
    rdfs:range ln:ProfessionalCertification ;
    rdfs:label "has certification"@en ;
    rdfs:comment "Note: Also exists in career/profile.ttl for backward compat"@en ;
    owl:inverseOf ln:certificationHeldBy .

ln:certificationHeldBy a owl:ObjectProperty ;
    rdfs:domain ln:ProfessionalCertification ;
    rdfs:range ln:Person ;
    rdfs:label "certification held by"@en ;
    owl:inverseOf ln:hasCertification .

# Relationships - Completion to Course
ln:completionOf a owl:ObjectProperty ;
    rdfs:domain ln:CourseCompletion ;
    rdfs:range ln:Course ;
    rdfs:label "completion of"@en .

# Relationships - Degree to Institution
ln:earnedFrom a owl:ObjectProperty ;
    rdfs:domain ln:Degree ;
    rdfs:range schema:Organization ;
    rdfs:label "earned from"@en ;
    rdfs:comment "University or institution that granted degree"@en .

# Relationships - Course to Institution
ln:offeredBy a owl:ObjectProperty ;
    rdfs:domain ln:Course ;
    rdfs:range schema:Organization ;
    rdfs:label "offered by"@en ;
    rdfs:comment "Platform or institution offering the course"@en .

# Relationships - Certification to Skills
ln:certifiesSkill a owl:ObjectProperty ;
    rdfs:domain ln:ProfessionalCertification ;
    rdfs:range ln:Skill ;
    rdfs:label "certifies skill"@en ;
    rdfs:comment "Skill validated by this certification"@en .

# Multi-tenancy
ln:tenantId a owl:DatatypeProperty ;
    rdfs:domain ln:EducationRecord ;
    rdfs:range xsd:string ;
    rdfs:label "tenant ID"@en ;
    rdfs:comment "Multi-tenant isolation identifier (HIPAA compliant)"@en .

# Metadata
<https://ln.life/ontology/education/credentials> a owl:Ontology ;
    dc:title "Life Navigator Education Credentials Ontology"@en ;
    dc:description "Ontology for education records, degrees, courses, certifications, and learning progress"@en ;
    dc:creator "Life Navigator"@en ;
    owl:versionInfo "1.0.0" .
