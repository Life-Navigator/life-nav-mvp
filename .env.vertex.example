# ============================================================================
# VERTEX AI CONFIGURATION (Production)
# ============================================================================

# GCP Project Configuration
GCP_PROJECT_ID=your-project-id-here
GCP_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# Gemini Model Configuration
GEMINI_MODEL=gemini-2.0-flash-exp
GEMINI_EMBEDDING_MODEL=text-embedding-004
ENABLE_GEMINI=true

# Legacy LLM Configuration (keep for future rollout)
ENABLE_VLLM=false
VLLM_INSTANCE_1=http://localhost:8090
VLLM_INSTANCE_2=http://localhost:8091

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# PostgreSQL (Primary)
POSTGRES_USER=lifenavigator
POSTGRES_PASSWORD=your-secure-password-here
POSTGRES_DB=lifenavigator_prod
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/lifenavigator

# Neo4j (Knowledge Graph)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password-here

# Redis (Cache & Message Bus)
REDIS_URL=redis://localhost:6379

# Qdrant (Vector Database)
QDRANT_URL=http://localhost:6333

# GraphDB (RDF/Turtle)
GRAPHDB_URL=http://localhost:7200

# ============================================================================
# APPLICATION SECURITY
# ============================================================================

SECRET_KEY=your-64-char-hex-secret-key-here
NEXTAUTH_SECRET=your-nextauth-secret-here
JWT_SECRET=your-jwt-secret-here

# ============================================================================
# EXTERNAL SERVICES (Optional)
# ============================================================================

# Anthropic (Optional - for future use)
ANTHROPIC_API_KEY=

# Plaid (Financial Connections)
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# Alpha Vantage (Stock Data)
ALPHA_VANTAGE_API_KEY=

# ============================================================================
# HIPAA COMPLIANCE
# ============================================================================

PHI_ENCRYPTION_KEY=your-phi-encryption-key-here
ENABLE_DATA_BOUNDARY=true
ENABLE_AUDIT_LOGGING=true

# ============================================================================
# MCP SERVER CONFIGURATION
# ============================================================================

MCP_SERVER_URL=http://localhost:8090
ENABLE_MCP=true

# ============================================================================
# GRAPHRAG CONFIGURATION
# ============================================================================

GRAPHRAG_URL=http://localhost:50051
ENABLE_GRAPHRAG=true

# ============================================================================
# CORS & SECURITY
# ============================================================================

CORS_ORIGINS=http://localhost:3000,http://localhost:3001
ALLOWED_HOSTS=localhost,127.0.0.1

# ============================================================================
# DEVELOPMENT FLAGS
# ============================================================================

DEBUG=false
LOG_LEVEL=info
ENVIRONMENT=production
