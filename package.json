{
  "name": "life-navigator-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Life Navigator - AI-powered life management platform",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:gen-types": "supabase gen types typescript --project-id $SUPABASE_PROJECT_ID > packages/supabase/src/database.types.ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "@turbo/gen": "^2.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "prettier": "^3.1.0",
    "supabase": "^1.200.0",
    "turbo": "^2.0.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "overrides": {
      "tinyexec": "1.0.4",
      "axios": ">=1.16.0",
      "handlebars": ">=4.7.9",
      "@xmldom/xmldom": ">=0.8.13",
      "node-forge": ">=1.4.0",
      "tar": ">=7.5.11",
      "picomatch": ">=4.0.4",
      "fast-xml-parser": ">=5.5.6",
      "fast-xml-builder": ">=1.1.7",
      "flatted": ">=3.4.2",
      "@babel/plugin-transform-modules-systemjs": ">=7.29.4"
    }
  },
  "packageManager": "pnpm@9.15.0",
  "lint-staged": {
    "apps/web/src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
