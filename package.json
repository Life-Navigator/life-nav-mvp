{
  "name": "life-navigator-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Life Navigator - Production-grade AI life management platform with dual-graph semantic architecture",
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:unit": "turbo run test:unit",
    "test:contract": "turbo run test:contract",
    "test:e2e": "turbo run test:e2e",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "clean": "turbo run clean && rm -rf node_modules",
    "codegen": "./scripts/codegen.sh",
    "local-dev": "./scripts/local-dev.sh",
    "security:scan": "turbo run security:scan",
    "security:secrets": "detect-secrets scan --baseline .secrets.baseline",
    "db:migrate:check": "turbo run db:migrate:check",
    "release-gate": "turbo run release-gate",
    "pre-deploy": "pnpm run release-gate"
  },
  "devDependencies": {
    "@turbo/gen": "^1.11.0",
    "turbo": "^1.11.0",
    "prettier": "^3.1.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.12.0",
  "pnpm": {
    "overrides": {
      "xml2js": ">=0.6.2",
      "xmldom": "npm:@xmldom/xmldom@^0.8.10",
      "@xmldom/xmldom": ">=0.8.10",
      "tmp": ">=0.2.4",
      "glob": ">=10.5.0",
      "js-yaml": ">=4.1.1",
      "node-forge": ">=1.3.2",
      "preact": ">=10.27.3"
    }
  }
}
