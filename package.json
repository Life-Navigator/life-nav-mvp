{
  "name": "life-navigator-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Life Navigator - AI-powered life management platform",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:gen-types": "supabase gen types typescript --project-id $SUPABASE_PROJECT_ID > packages/supabase/src/database.types.ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "@turbo/gen": "^2.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "prettier": "^3.1.0",
    "supabase": "^1.200.0",
    "turbo": "^2.0.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": "20.x",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "overrides": {
      "tinyexec": "1.0.4",
      "axios": ">=1.16.0",
      "handlebars": ">=4.7.9",
      "@xmldom/xmldom": ">=0.8.13",
      "node-forge": ">=1.4.0",
      "tar": ">=7.5.11",
      "picomatch": ">=4.0.4",
      "fast-xml-parser": ">=5.5.6",
      "fast-xml-builder": ">=1.1.7",
      "flatted": ">=3.4.2",
      "@babel/plugin-transform-modules-systemjs": ">=7.29.4",
      "shell-quote": ">=1.8.4",
      "form-data@2": ">=2.5.6",
      "form-data@3": ">=3.0.5",
      "form-data@4": ">=4.0.6",
      "lodash": ">=4.18.0",
      "@babel/core": ">=7.29.6 <8",
      "@tootallnate/once": ">=2.0.1",
      "brace-expansion@1": "1.1.13",
      "brace-expansion@2": ">=2.0.3",
      "brace-expansion@4": "5.0.7",
      "brace-expansion@5": "5.0.7",
      "dompurify": ">=3.4.0",
      "js-yaml@3": "3.15.0",
      "js-yaml@4": ">=4.2.0",
      "postcss": ">=8.5.10",
      "turbo": ">=2.9.14",
      "undici": ">=6.27.0 <7",
      "uuid": ">=11.1.1",
      "ws@6": ">=6.2.4",
      "ws@7": ">=7.5.11",
      "ws@8": ">=8.20.1",
      "yaml": ">=2.8.3"
    }
  },
  "packageManager": "pnpm@9.15.0",
  "lint-staged": {
    "apps/web/src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
