}

//=====================
// SOCIAL NETWORK INTEGRATION
//=====================

model SocialNetworkConnection {
  id               String               @id @default(cuid())
  userId           String
  platform         String               // linkedin, instagram, twitter, tiktok
  username         String
  displayName      String?
  profileUrl       String?
  profileImageUrl  String?
  accessToken      String?              @db.Text
  refreshToken     String?              @db.Text
  expiresAt        DateTime?
  status           String               @default("active") // active, error, expired
  lastSyncedAt     DateTime             @default(now())
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  // Relations
  user             User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  metrics          SocialNetworkMetric[]
  followers        SocialNetworkFollower[]

  @@unique([userId, platform, username])
  @@index([userId])
  @@index([platform])
  @@map("social_network_connections")
}

model SocialNetworkMetric {
  id                     String                  @id @default(cuid())
  socialNetworkConnectionId String
  date                   DateTime                @default(now())
  followersCount         Int                     @default(0)
  followingCount         Int                     @default(0)
  postsCount             Int                     @default(0)
  engagementRate         Float?                  // Percentage
  impressions            Int?
  reach                  Int?
  profileViews           Int?
  linkClicks             Int?
  estimatedValue         Float?                  // Calculated network value in USD
  createdAt              DateTime                @default(now())

  // Relations
  socialNetworkConnection SocialNetworkConnection @relation(fields: [socialNetworkConnectionId], references: [id], onDelete: Cascade)

  @@index([socialNetworkConnectionId])
  @@index([date])
  @@map("social_network_metrics")
}

model SocialNetworkFollower {
  id                     String                  @id @default(cuid())
  socialNetworkConnectionId String
  followerId             String                  // External follower ID
  username               String
  displayName            String?
  profileUrl             String?
  followerCount          Int?                    // Their follower count
  verifiedStatus         Boolean                 @default(false)
  influenceScore         Float?                  // Calculated influence 0-100
  industry               String?
  location               String?
  bio                    String?                 @db.Text
  engagementRate         Float?
  lastInteraction        DateTime?
  addedAt                DateTime                @default(now())
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt

  // Relations
  socialNetworkConnection SocialNetworkConnection @relation(fields: [socialNetworkConnectionId], references: [id], onDelete: Cascade)

  @@unique([socialNetworkConnectionId, followerId])
  @@index([socialNetworkConnectionId])
  @@index([influenceScore])
  @@map("social_network_followers")
}

//=====================
// NETWORK VALUE INSIGHTS
//=====================

model NetworkValueInsight {
  id               String   @id @default(cuid())
  userId           String
  platform         String   // linkedin, instagram, twitter, tiktok, overall
  insightType      String   // growth_rate, engagement_trend, high_value_connections, monetization_potential
  title            String
  description      String   @db.Text
  value            Float?   // Quantified value if applicable
  score            Int?     // Score 0-100
  recommendations  String?  @db.Text // JSON array of recommendations
  dataPoints       String?  @db.Text // JSON data supporting the insight
  generatedAt      DateTime @default(now())
  validUntil       DateTime?
  createdAt        DateTime @default(now())

  // Relations
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([platform])
  @@index([generatedAt])
  @@map("network_value_insights")
}

//=====================
// TAX PLANNING MODELS
//=====================

model TaxProfile {
  id                    String              @id @default(cuid())
  userId                String
  taxYear               Int
  filingStatus          String              // single, married_jointly, married_separately, head_of_household
  state                 String?             // State code for state tax calculations
  dependents            Int                 @default(0)
  isBlind               Boolean             @default(false)
  isOver65              Boolean             @default(false)
  spouseIsBlind         Boolean             @default(false)
  spouseIsOver65        Boolean             @default(false)

  // W-4 Data
  multipleJobs          Boolean             @default(false)
  claimDependents       Float               @default(0)
  otherIncome           Float               @default(0)
  deductionsW4          Float               @default(0)
  extraWithholding      Float               @default(0)

  // Status
  status                String              @default("draft") // draft, in_progress, completed, filed
  lastCalculatedAt      DateTime?
  notes                 String?             @db.Text

  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  // Relations
  user                  User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  incomes               TaxIncome[]
  deductions            TaxDeduction[]
  credits               TaxCredit[]
  estimates             TaxEstimate[]
  scenarios             TaxScenario[]
  documents             TaxDocument[]
  quarterlyPayments     QuarterlyTaxPayment[]
  optimizations         TaxOptimization[]
  deductionOpportunities DeductionOpportunity[]
  strategies            TaxStrategy[]

  @@unique([userId, taxYear])
  @@index([userId])
  @@index([taxYear])
  @@index([status])
  @@map("tax_profiles")
}

model TaxIncome {
  id                String      @id @default(cuid())
  taxProfileId      String
  category          String      // wages, self_employment, business, rental, interest, dividends, capital_gains, retirement, social_security, other
  subcategory       String?     // qualified_dividends, short_term_gains, long_term_gains, etc.
  source            String      // Employer name, business name, bank name, etc.
  amount            Float
  frequency         String      @default("annual") // annual, monthly, biweekly, weekly, one_time
  taxWithheld       Float       @default(0)
  is1099            Boolean     @default(false)
  isW2              Boolean     @default(false)
  employerEIN       String?

  // For self-employment/business income
  expenses          Float       @default(0)
  netIncome         Float?      // Calculated: amount - expenses
  qbiEligible       Boolean     @default(false) // Qualified Business Income deduction eligibility

  // For investment income
  costBasis         Float?
  acquisitionDate   DateTime?
  isQualified       Boolean     @default(false) // For qualified dividends

  // For rental income
  propertyAddress   String?
  daysRented        Int?
  daysPersonalUse   Int?

  notes             String?
  documentIds       String[]    // References to TaxDocument ids
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  // Relations
  taxProfile        TaxProfile  @relation(fields: [taxProfileId], references: [id], onDelete: Cascade)

  @@index([taxProfileId])
  @@index([category])
  @@map("tax_incomes")
}

model TaxDeduction {
  id                String      @id @default(cuid())
  taxProfileId      String
  category          String      // standard, itemized, above_the_line, business
  type              String      // mortgage_interest, property_tax, charitable, medical, state_local_tax, student_loan, educator_expense, hsa, ira, 401k, etc.
  description       String
  amount            Float
  isRecurring       Boolean     @default(false)
  frequency         String?     // monthly, annual, one_time

  // For itemized deductions
  limitApplies      Boolean     @default(false)
  limitAmount       Float?
  agiPhaseoutStart  Float?
  agiPhaseoutEnd    Float?

  // For charitable contributions
  recipientName     String?
  recipientEIN      String?
  isCash            Boolean     @default(true)
  fairMarketValue   Float?

  // For mortgage interest
  lenderName        String?
  loanNumber        String?
  propertyAddress   String?
  isFirstMortgage   Boolean     @default(true)
  loanOriginationDate DateTime?
  originalLoanAmount Float?

  // For medical expenses
  agiThreshold      Float?      // 7.5% of AGI floor

  documentIds       String[]
  notes             String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  // Relations
  taxProfile        TaxProfile  @relation(fields: [taxProfileId], references: [id], onDelete: Cascade)

  @@index([taxProfileId])
  @@index([category])
  @@index([type])
  @@map("tax_deductions")
}

model TaxCredit {
  id                String      @id @default(cuid())
  taxProfileId      String
  type              String      // child_tax_credit, dependent_care, education_aotc, education_llc, earned_income, child_dependent_care, adoption, saver, foreign_tax, energy, ev_credit, premium_tax, etc.
  name              String
  amount            Float
  isRefundable      Boolean     @default(false)
  isPartiallyRefundable Boolean @default(false)
  refundableAmount  Float?

  // Phase-out information
  agiPhaseoutStart  Float?
  agiPhaseoutEnd    Float?
  phaseoutRate      Float?      // Percentage reduction per $1000 over threshold

  // For child tax credit
  qualifyingChildren Int?
  childrenUnder6    Int?
  childrenUnder17   Int?

  // For education credits
  studentName       String?
  institutionName   String?
  qualifiedExpenses Float?
  form1098T         Boolean     @default(false)

  // For EV credit
  vehicleVIN        String?
  vehicleMake       String?
  vehicleModel      String?
  purchaseDate      DateTime?
  msrp              Float?
  batteryCapacity   Float?      // kWh

  // For energy credits
  propertyType      String?     // solar, wind, geothermal, battery, heat_pump, etc.
  installationCost  Float?
  installationDate  DateTime?

  documentIds       String[]
  notes             String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  // Relations
  taxProfile        TaxProfile  @relation(fields: [taxProfileId], references: [id], onDelete: Cascade)

  @@index([taxProfileId])
  @@index([type])
  @@map("tax_credits")
}

model TaxEstimate {
  id                    String      @id @default(cuid())
  taxProfileId          String
  calculatedAt          DateTime    @default(now())
  scenarioId            String?     // Optional link to scenario for what-if analysis

  // Income Summary
  grossIncome           Float
  adjustedGrossIncome   Float
  taxableIncome         Float

  // Above-the-line deductions
  aboveLineDeductions   Float       @default(0)

  // Deduction Summary
  standardDeduction     Float
  itemizedDeductions    Float
  deductionUsed         String      // standard, itemized
  totalDeductions       Float

  // QBI Deduction
  qbiDeduction          Float       @default(0)

  // Tax Calculations
  ordinaryIncomeTax     Float
  capitalGainsTax       Float       @default(0)
  selfEmploymentTax     Float       @default(0)
  additionalMedicareTax Float       @default(0)
  netInvestmentIncomeTax Float      @default(0) // 3.8% NIIT
  alternativeMinimumTax Float       @default(0)

  totalTaxBeforeCredits Float

  // Credits
  nonrefundableCredits  Float       @default(0)
  refundableCredits     Float       @default(0)
  totalCredits          Float

  // Final Tax
  totalTaxLiability     Float
  totalWithholding      Float       @default(0)
  estimatedPayments     Float       @default(0)
  totalPayments         Float

  // Result
  refundOrOwed          Float       // Positive = refund, Negative = owed

  // Rates
  marginalRate          Float
  effectiveRate         Float

  // State Tax (if applicable)
  stateTaxableIncome    Float?
  stateTax              Float?
  stateCredits          Float?
  stateRefundOrOwed     Float?

  // Combined
  totalFederalAndState  Float?
  combinedEffectiveRate Float?

  // Breakdown JSON for detailed analysis
  breakdown             Json?       // Detailed bracket-by-bracket breakdown

  createdAt             DateTime    @default(now())

  // Relations
  taxProfile            TaxProfile  @relation(fields: [taxProfileId], references: [id], onDelete: Cascade)
  scenario              TaxScenario? @relation(fields: [scenarioId], references: [id], onDelete: SetNull)

  @@index([taxProfileId])
  @@index([calculatedAt])
  @@map("tax_estimates")
}

model TaxScenario {
  id                String        @id @default(cuid())
  taxProfileId      String
  name              String
  description       String?

  // Scenario modifications (stored as JSON diffs from base profile)
  incomeChanges     Json?         // { "add": [], "modify": [], "remove": [] }
  deductionChanges  Json?
  creditChanges     Json?
  filingStatusChange String?

  // Comparison metrics
  baselineTax       Float?
  scenarioTax       Float?
  taxDifference     Float?

  // Recommendations
  isRecommended     Boolean       @default(false)
  priority          Int           @default(0) // Higher = more important

  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  // Relations
  taxProfile        TaxProfile    @relation(fields: [taxProfileId], references: [id], onDelete: Cascade)
  estimates         TaxEstimate[]

  @@index([taxProfileId])
  @@map("tax_scenarios")
}

model TaxOptimization {
  id                String      @id @default(cuid())
  taxProfileId      String
  category          String      // income_timing, deduction_bunching, retirement_contribution, charitable_giving, tax_loss_harvesting, roth_conversion, hsa_contribution, business_structure, etc.
  title             String
  description       String      @db.Text

  // Impact
  estimatedSavings  Float
  confidenceLevel   String      // high, medium, low
  timeframe         String      // immediate, this_year, multi_year
  complexity        String      // simple, moderate, complex

  // Implementation
  actionRequired    String      @db.Text
  deadline          DateTime?
  requirements      Json?       // Prerequisites or conditions
  risks             String?     @db.Text

  // Status
  status            String      @default("suggested") // suggested, considering, implemented, dismissed
  implementedAt     DateTime?
  actualSavings     Float?

  // Source
  source            String      @default("system") // system, user, advisor

  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  // Relations
  taxProfile        TaxProfile  @relation(fields: [taxProfileId], references: [id], onDelete: Cascade)

  @@index([taxProfileId])
  @@index([category])
  @@index([status])
  @@map("tax_optimizations")
}

model QuarterlyTaxPayment {
  id                String      @id @default(cuid())
  taxProfileId      String
  quarter           Int         // 1, 2, 3, 4
  dueDate           DateTime

  // Amounts
  requiredPayment   Float       // Based on safe harbor or current year estimate
  actualPayment     Float       @default(0)
  paymentDate       DateTime?

  // Safe Harbor Calculations
  priorYearTax      Float?
  currentYearEstimate Float?
  safeHarborAmount  Float?

  // Penalty avoidance
  isUnderpaid       Boolean     @default(false)
  penaltyAmount     Float?

  // Status
  status            String      @default("pending") // pending, paid, partial, overdue
  confirmationNumber String?
  paymentMethod     String?     // eftps, direct_pay, check, irs_online

  notes             String?
  documentIds       String[]
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  // Relations
  taxProfile        TaxProfile  @relation(fields: [taxProfileId], references: [id], onDelete: Cascade)

  @@unique([taxProfileId, quarter])
  @@index([taxProfileId])
  @@index([dueDate])
  @@index([status])
  @@map("quarterly_tax_payments")
}

model TaxDocument {
  id                String      @id @default(cuid())
  taxProfileId      String
  type              String      // w2, 1099_misc, 1099_nec, 1099_div, 1099_int, 1099_b, 1099_r, 1098, 1098_t, 1098_e, k1, receipts, other
  year              Int
  issuerName        String
  issuerEIN         String?

  // Status
  status            String      @default("pending") // pending, received, reviewed, entered, filed
  receivedDate      DateTime?
  reviewedDate      DateTime?
  enteredDate       DateTime?

  // Document Details
  documentNumber    String?     // Control number for W-2s, etc.
  grossAmount       Float?      // Total income/amount on document
  taxWithheld       Float?      // Federal tax withheld
  stateTaxWithheld  Float?

  // File Storage
  fileUrl           String?
  fileName          String?
  fileType          String?     // pdf, jpg, png
  fileSize          Int?
  ocrText           String?     @db.Text // Extracted text for searchability
  ocrData           Json?       // Structured data extracted via OCR

  // Validation
  isValidated       Boolean     @default(false)
  validationErrors  Json?       // Any discrepancies found

  notes             String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  // Relations
  taxProfile        TaxProfile  @relation(fields: [taxProfileId], references: [id], onDelete: Cascade)

  @@index([taxProfileId])
  @@index([type])
  @@index([year])
  @@index([status])
  @@map("tax_documents")
}

model TaxDeadline {
  id                String      @id @default(cuid())
  name              String
  description       String
  dueDate           DateTime
  category          String      // filing, payment, forms, retirement, healthcare, business, estimated_tax
  applicableTo      String[]    // individual, business, self_employed, etc.
  filingStatus      String[]    // Which filing statuses this applies to
  form              String?     // Form number (1040, 1120, etc.)
  isExtendable      Boolean     @default(false)
  extensionDeadline DateTime?
  penaltyInfo       String?     @db.Text
  resourceUrl       String?     // IRS or official resource link
  isRecurring       Boolean     @default(true)

  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@index([dueDate])
  @@index([category])
  @@map("tax_deadlines")
}

//=====================
// EMPLOYER BENEFITS & COMPENSATION
//=====================

model EmployerBenefits {
  id                String      @id @default(cuid())
  userId            String
  employerName      String
  isCurrentEmployer Boolean     @default(true)
  startDate         DateTime?
  endDate           DateTime?

  // Compensation
  baseSalary        Float?
  bonusTarget       Float?      // Target bonus percentage
  bonusStructure    String?     // annual, quarterly, monthly
  signOnBonus       Float?
  relocationBonus   Float?
  stockGrants       Float?      // Total value of equity grants
  vestingSchedule   String?     // 4-year cliff, immediate, etc.

  // Offer Letter Document
  offerLetterUrl    String?
  offerLetterFileName String?
  offerLetterUploadedAt DateTime?
  offerLetterParsedData Json?   // AI-extracted data from offer letter

  // Benefits Summary Document
  benefitsSummaryUrl String?
  benefitsSummaryFileName String?
  benefitsSummaryUploadedAt DateTime?
  benefitsSummaryParsedData Json?

  notes             String?     @db.Text
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  // Relations
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  healthBenefits    HealthBenefit[]
  retirementBenefits RetirementBenefit[]
  additionalBenefits AdditionalBenefit[]
  deductionOpportunities DeductionOpportunity[]

  @@index([userId])
  @@index([isCurrentEmployer])
  @@map("employer_benefits")
}

model HealthBenefit {
  id                String      @id @default(cuid())
  employerBenefitsId String

  // Plan Details
  planType          String      // medical, dental, vision, life, disability_short, disability_long, fsa, dcfsa, hsa
  planName          String?
  carrier           String?
  coverageLevel     String?     // employee_only, employee_spouse, employee_children, family

  // Costs
  employeePremium   Float?      // Per pay period employee cost
  employerContribution Float?   // Employer contribution
  premiumFrequency  String?     // weekly, biweekly, monthly
  annualPremium     Float?      // Calculated annual cost

  // Coverage Details
  deductible        Float?
  outOfPocketMax    Float?
  coinsurance       Float?
  copay             Float?

  // HSA/FSA specifics
  hsaEligible       Boolean     @default(false)
  hsaEmployerContribution Float?
  fsaLimit          Float?
  dcfsaLimit        Float?

  // Life/Disability
  coverageAmount    Float?      // Life insurance coverage
  coverageMultiple  Float?      // e.g., 2x salary
  beneficiaryInfo   String?

  isEnrolled        Boolean     @default(false)
  enrollmentDeadline DateTime?
  effectiveDate     DateTime?

  notes             String?     @db.Text
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  // Relations
  employerBenefits  EmployerBenefits @relation(fields: [employerBenefitsId], references: [id], onDelete: Cascade)

  @@index([employerBenefitsId])
  @@index([planType])
  @@map("health_benefits")
}

model RetirementBenefit {
  id                String      @id @default(cuid())
  employerBenefitsId String

  // Plan Details
  planType          String      // 401k, 403b, 457b, pension, espp, stock_purchase, roth_401k
  planName          String?
  administrator     String?     // Fidelity, Vanguard, etc.

  // Contribution Details
  employeeContributionLimit Float? // Annual limit
  employeeContributionPct Float?   // Current contribution %
  employeeContributionAmt Float?   // Current contribution $

  // Employer Match
  employerMatchPct  Float?      // e.g., 50% or 100%
  employerMatchLimit Float?     // Up to X% of salary
  employerMatchCap  Float?      // Maximum $ match
  vestingSchedule   String?     // immediate, 3-year cliff, 6-year graded
  vestingPct        Float?      // Current vesting percentage

  // ESPP specifics
  esppDiscount      Float?      // e.g., 15%
  esppLookback      Boolean     @default(false)
  esppContributionLimit Float?

  // Pension specifics
  pensionFormula    String?     // e.g., 2% x years of service x final average salary
  pensionEligibility String?   // e.g., age 65 with 5 years of service

  // Mega Backdoor Roth
  afterTaxContribAllowed Boolean @default(false)
  inPlanRothConversion Boolean  @default(false)

  isEnrolled        Boolean     @default(false)
  enrollmentDeadline DateTime?

  notes             String?     @db.Text
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  // Relations
  employerBenefits  EmployerBenefits @relation(fields: [employerBenefitsId], references: [id], onDelete: Cascade)

  @@index([employerBenefitsId])
  @@index([planType])
  @@map("retirement_benefits")
}

// Investment Holdings - Individual securities in user's portfolio
model InvestmentHolding {
  id                String   @id @default(cuid())
  userId            String

  // Security identification
  ticker            String              // Stock symbol (e.g., AAPL, MSFT)
  name              String              // Company name
  assetType         String   @default("stock") // stock, etf, mutual_fund, bond, crypto, option

  // Position details
  shares            Float               // Number of shares
  costBasis         Float               // Average cost per share
  purchaseDate      DateTime?           // Date of purchase

  // Current valuation
  currentPrice      Float    @default(0) // Current price per share
  marketValue       Float    @default(0) // shares * currentPrice
  lastPriceUpdate   DateTime @default(now())

  // Gains/Losses
  unrealizedGain    Float    @default(0) // marketValue - (shares * costBasis)
  unrealizedGainPct Float    @default(0) // % gain/loss

  // Classification
  sector            String?             // technology, healthcare, financial, etc.
  industry          String?             // More specific industry
  region            String   @default("US") // US, International, Emerging
  marketCap         String?             // large_cap, mid_cap, small_cap

  // Market data (updated periodically)
  dividendYield     Float    @default(0)
  beta              Float    @default(1.0)
  peRatio           Float?
  fiftyTwoWeekHigh  Float?
  fiftyTwoWeekLow   Float?

  // Tax lot tracking
  taxLotMethod      String   @default("FIFO") // FIFO, LIFO, SpecID, AvgCost
  isLongTerm        Boolean  @default(false) // > 1 year holding period

  // Account information
  accountId         String?             // If linked to a specific account
  accountName       String?             // e.g., "Fidelity Brokerage"
  accountType       String   @default("taxable") // taxable, traditional_ira, roth_ira, 401k

  // Data source
  source            String   @default("manual") // manual, plaid, csv_import
  plaidSecurityId   String?             // Plaid security ID if from Plaid

  notes             String?  @db.Text
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, ticker, accountId])
  @@index([userId])
  @@index([ticker])
  @@index([sector])
  @@index([assetType])
  @@map("investment_holdings")
}

model AdditionalBenefit {
  id                String      @id @default(cuid())
  employerBenefitsId String

  // Benefit Details
  category          String      // pto, parental_leave, education, wellness, commuter, legal, pet, adoption, fertility, mental_health, gym, phone, internet, equipment
  name              String
  description       String?     @db.Text

  // Value
  annualValue       Float?      // Monetary value if applicable
  frequency         String?     // annual, monthly, one_time, unlimited

  // Limits
  maxAmount         Float?
  usedAmount        Float?
  remainingAmount   Float?

  // PTO specifics
  ptoAccrualRate    Float?      // Hours per pay period
  ptoMaxCarryover   Float?
  ptoCurrentBalance Float?

  // Education specifics
  tuitionReimbursement Float?
  certificationBudget Float?
  conferenceBudget  Float?

  // Wellness specifics
  wellnessStipend   Float?
  gymReimbursement  Float?

  // Commuter specifics
  commuterBenefit   Float?      // Monthly limit
  parkingBenefit    Float?

  isEnrolled        Boolean     @default(false)
  enrollmentDeadline DateTime?
  expirationDate    DateTime?

  notes             String?     @db.Text
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  // Relations
  employerBenefits  EmployerBenefits @relation(fields: [employerBenefitsId], references: [id], onDelete: Cascade)

  @@index([employerBenefitsId])
  @@index([category])
  @@map("additional_benefits")
}

model DeductionOpportunity {
  id                String      @id @default(cuid())
  userId            String
  employerBenefitsId String?
  taxProfileId      String?

  // Opportunity Details
  category          String      // retirement, healthcare, education, charitable, business, home_office, vehicle, professional, investment, other
  type              String      // specific deduction type
  title             String
  description       String      @db.Text

  // Financial Impact
  currentAmount     Float       @default(0)  // What user is currently utilizing
  maxAmount         Float?      // Maximum available deduction
  potentialSavings  Float?      // Estimated tax savings
  marginalRateUsed  Float?      // Tax rate used to calculate savings

  // Source & Eligibility
  source            String      // employer_benefit, irs_rule, state_rule, identified_expense, goal_aligned
  eligibilityRules  Json?       // Rules/requirements for eligibility
  isEligible        Boolean     @default(true)
  eligibilityNotes  String?

  // Action & Status
  status            String      @default("identified") // identified, considering, planned, implemented, declined
  actionRequired    String?     @db.Text
  implementationSteps Json?     // Step-by-step guide
  deadline          DateTime?   // Deadline to take action

  // Goal Alignment
  alignedGoalIds    String[]    // IDs of goals this supports
  alignmentReason   String?     @db.Text

  // Priority & Confidence
  priority          Int         @default(5) // 1-10, higher is more important
  confidenceLevel   String      @default("medium") // low, medium, high
  complexity        String      @default("moderate") // simple, moderate, complex

  // Tracking
  implementedAt     DateTime?
  implementedAmount Float?
  actualSavings     Float?

  notes             String?     @db.Text
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  // Relations
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  employerBenefits  EmployerBenefits? @relation(fields: [employerBenefitsId], references: [id], onDelete: SetNull)
  taxProfile        TaxProfile? @relation(fields: [taxProfileId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([category])
  @@index([status])
  @@index([priority])
  @@map("deduction_opportunities")
}

model TaxStrategy {
  id                String      @id @default(cuid())
  userId            String
  taxProfileId      String?

  // Strategy Details
  name              String
  category          String      // income_timing, retirement, investment, business, estate, education, charitable, healthcare, real_estate, tax_loss_harvesting
  description       String      @db.Text

  // Implementation
  currentStatus     String      @default("not_started") // not_started, in_progress, implemented, monitoring, completed
  implementationPlan Json?      // Step-by-step implementation guide
  startDate         DateTime?
  targetCompletionDate DateTime?
  completedDate     DateTime?

  // Financial Impact
  estimatedAnnualSavings Float?
  estimatedLifetimeSavings Float?
  implementationCost Float?     // Cost to implement (professional fees, etc.)
  roi               Float?      // Return on investment

  // Risk & Complexity
  riskLevel         String      @default("low") // low, medium, high
  complexity        String      @default("moderate") // simple, moderate, complex, expert
  requiresProfessional Boolean  @default(false)

  // Goal Alignment
  alignedGoalIds    String[]
  alignmentScore    Float?      // 0-100 how well it aligns with goals

  // Timeline
  timeHorizon       String      @default("annual") // immediate, this_year, annual, multi_year, lifetime
  recurringBenefit  Boolean     @default(false)

  // Prerequisites
  prerequisites     Json?       // What needs to be in place first

  // Documentation
  relatedDocuments  String[]    // Document IDs
  referenceLinks    String[]    // IRS links, articles, etc.

  // Review
  lastReviewDate    DateTime?
  nextReviewDate    DateTime?
  reviewNotes       String?     @db.Text

  notes             String?     @db.Text
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  // Relations
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  taxProfile        TaxProfile? @relation(fields: [taxProfileId], references: [id], onDelete: SetNull)
  milestones        TaxStrategyMilestone[]

  @@index([userId])
  @@index([category])
  @@index([currentStatus])
  @@map("tax_strategies")
}

model TaxStrategyMilestone {
  id                String      @id @default(cuid())
  taxStrategyId     String

  // Milestone Details
  title             String
  description       String?
  order             Int

  // Status
  status            String      @default("pending") // pending, in_progress, completed, skipped
  dueDate           DateTime?
  completedDate     DateTime?

  // Action
  actionItems       Json?       // List of specific actions
  assignedTo        String?     // User or professional

  notes             String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  // Relations
  taxStrategy       TaxStrategy @relation(fields: [taxStrategyId], references: [id], onDelete: Cascade)

  @@index([taxStrategyId])
  @@index([status])
  @@map("tax_strategy_milestones")
}

// ============================================================================
// COMPREHENSIVE RETIREMENT PLANNING SYSTEM
// Industry-leading retirement planning models that exceed MoneyGuidePro, eMoney,
// and Fidelity capabilities with advanced projections, scenarios, and optimizations
// ============================================================================

model RetirementPlan {
  id                String      @id @default(cuid())
  userId            String

  // Basic Information
  name              String      @default("My Retirement Plan")
  status            String      @default("active") // draft, active, archived
  primaryPlanHolder String?     // Name
  spouseName        String?     // For couples planning

  // Demographics
  currentAge        Int
  spouseCurrentAge  Int?
  targetRetirementAge Int       @default(65)
  spouseRetirementAge Int?
  lifeExpectancy    Int         @default(95)
  spouseLifeExpectancy Int?

  // Current Financial Status
  currentAnnualIncome Float
  spouseAnnualIncome Float?
  currentNetWorth   Float       @default(0)
  annualExpenses    Float?      // Current annual spending

  // Retirement Goals
  desiredRetirementIncome Float? // Annual income target in retirement
  incomeReplacementRatio Float   @default(80) // % of pre-retirement income
  retirementIncomeMethod String  @default("replacement_ratio") // replacement_ratio, fixed_amount, expense_based

  // Legacy & Estate
  legacyGoal        Float       @default(0) // Amount to leave to heirs
  charitableGoal    Float       @default(0) // Charitable giving in retirement

  // Inflation Assumptions
  generalInflation  Float       @default(2.5)
  healthcareInflation Float     @default(5.5)
  educationInflation Float      @default(4.0)

  // Risk Profile
  riskTolerance     String      @default("moderate") // conservative, moderately_conservative, moderate, moderately_aggressive, aggressive
  equityAllocation  Float       @default(60) // Current equity %
  targetEquityInRetirement Float @default(40) // Target equity % at retirement
  glidepathStrategy String      @default("linear") // linear, bucketed, dynamic, static

  // Settings
  includeSpouse     Boolean     @default(false)
  useMonteCarlo     Boolean     @default(true)
  monteCarloRuns    Int         @default(1000)

  notes             String?     @db.Text
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  // Relations
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  accounts          RetirementAccount[]
  incomeStreams     RetirementIncomeStream[]
  expenses          RetirementExpense[]
  scenarios         RetirementScenario[]
  projections       RetirementProjection[]
  socialSecurity    SocialSecurityBenefit[]
  healthcarePlans   RetirementHealthcarePlan[]
  withdrawalStrategies WithdrawalStrategy[]
  rothConversions   RothConversionPlan[]
  milestones        RetirementMilestone[]

  @@unique([userId, name])
  @@index([userId])
  @@index([status])
  @@map("retirement_plans")
}

model RetirementAccount {
  id                String      @id @default(cuid())
  retirementPlanId  String

  // Account Details
  accountName       String
  accountType       String      // 401k, 403b, 457b, traditional_ira, roth_ira, roth_401k, sep_ira, simple_ira, solo_401k, pension, annuity, brokerage, savings, hsa, other
  institution       String?     // Fidelity, Vanguard, etc.
  accountNumber     String?     // Last 4 digits for reference

  // Owner
  owner             String      @default("primary") // primary, spouse, joint

  // Balances
  currentBalance    Float
  costBasis         Float?      // For taxable accounts
  unrealizedGains   Float?

  // Contributions
  annualContribution Float      @default(0)
  contributionFrequency String  @default("per_paycheck") // per_paycheck, monthly, annual
  employerMatch     Float?      // Dollar amount of employer match
  employerMatchPct  Float?      // Percentage match
  employerMatchLimit Float?     // Max % of salary matched
  vestingPct        Float       @default(100)

  // Contribution Limits
  contributionLimit Float?      // IRS limit for this account type
  catchUpEligible   Boolean     @default(false)
  catchUpAmount     Float?      // Additional catch-up contribution

  // Growth Assumptions
  expectedReturn    Float       @default(7.0) // Annual return %
  returnVolatility  Float       @default(15.0) // Standard deviation %

  // Asset Allocation
  equityPct         Float       @default(60)
  bondsPct          Float       @default(30)
  cashPct           Float       @default(5)
  alternativesPct   Float       @default(5)

  // Holdings Detail (optional)
  holdings          Json?       // Detailed holdings [{symbol, shares, value, allocation}]

  // Tax Treatment
  taxTreatment      String      @default("tax_deferred") // tax_deferred, tax_free, taxable, partially_taxable
  rmdRequired       Boolean     @default(false)
  rmdStartAge       Int?        // Age when RMDs begin (73, 75, etc.)

  // Fees
  expenseRatio      Float       @default(0.5) // Annual expense ratio %
  advisorFee        Float       @default(0)   // Annual advisor fee %

  // Linked External Account
  plaidAccountId    String?
  lastSyncedAt      DateTime?

  // Beneficiaries
  beneficiaries     Json?       // [{name, relationship, percentage, type: primary|contingent}]

  isActive          Boolean     @default(true)
  notes             String?     @db.Text
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  // Relations
  retirementPlan    RetirementPlan @relation(fields: [retirementPlanId], references: [id], onDelete: Cascade)
  transactions      RetirementTransaction[]

  @@index([retirementPlanId])
  @@index([accountType])
  @@index([owner])
  @@map("retirement_accounts")
}

model RetirementTransaction {
  id                String      @id @default(cuid())
  retirementAccountId String

  // Transaction Details
  type              String      // contribution, withdrawal, dividend, interest, transfer_in, transfer_out, roth_conversion, rebalance, fee
  amount            Float
  date              DateTime
  description       String?

  // For Conversions
  fromAccountType   String?
  toAccountType     String?
  taxableAmount     Float?

  // Categorization
  category          String?     // employer_match, employee_contribution, rollover, rmd, hardship, qualified_distribution

  createdAt         DateTime    @default(now())

  // Relations
  retirementAccount RetirementAccount @relation(fields: [retirementAccountId], references: [id], onDelete: Cascade)

  @@index([retirementAccountId])
  @@index([date])
  @@index([type])
  @@map("retirement_transactions")
}

model RetirementIncomeStream {
  id                String      @id @default(cuid())
  retirementPlanId  String

  // Income Source Details
  name              String
  type              String      // social_security, pension, annuity, rental, part_time_work, royalties, business_income, inheritance, trust_distribution, other
  owner             String      @default("primary") // primary, spouse, joint

  // Amount
  annualAmount      Float
  monthlyAmount     Float?

  // Timing
  startAge          Int         // Age when income begins
  endAge            Int?        // Age when income ends (null = lifetime)
  startDate         DateTime?   // Specific start date
  endDate           DateTime?   // Specific end date

  // Adjustments
  inflationAdjusted Boolean     @default(false)
  colaRate          Float?      // Cost of living adjustment %
  taxable           Boolean     @default(true)
  taxRate           Float?      // Specific tax rate if known

  // Pension Specifics
  pensionType       String?     // single_life, joint_survivor, period_certain, lump_sum
  survivorBenefit   Float?      // % survivor receives
  certainPeriod     Int?        // Years for period certain
  lumpSumOption     Float?      // Lump sum value if available

  // Annuity Specifics
  annuityType       String?     // immediate, deferred, fixed, variable, indexed
  guaranteedPeriod  Int?
  deathBenefit      Float?

  // Probability
  probability       Float       @default(100) // % probability of receiving this income (for planning uncertainty)

  isActive          Boolean     @default(true)
  notes             String?     @db.Text
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  // Relations
  retirementPlan    RetirementPlan @relation(fields: [retirementPlanId], references: [id], onDelete: Cascade)

  @@index([retirementPlanId])
  @@index([type])
  @@index([owner])
  @@map("retirement_income_streams")
}

model RetirementExpense {
  id                String      @id @default(cuid())
  retirementPlanId  String

  // Expense Details
  name              String
  category          String      // housing, healthcare, food, transportation, utilities, insurance, entertainment, travel, hobbies, family_support, charitable, taxes, debt_payments, other

  // Amount
  annualAmount      Float
  monthlyAmount     Float?

  // Timing
  startAge          Int?        // When expense begins (null = now)
  endAge            Int?        // When expense ends (null = lifetime)

  // Adjustments
  inflationType     String      @default("general") // general, healthcare, custom, none
  customInflation   Float?      // Custom inflation rate if applicable

  // Flexibility
  priority          String      @default("essential") // essential, important, discretionary, luxury
  canReduce         Boolean     @default(true)
  reductionPct      Float?      // How much can be reduced if needed

  // One-time vs Recurring
  isRecurring       Boolean     @default(true)
  oneTimeYear       Int?        // If one-time, which year

  // For Housing
  isMortgage        Boolean     @default(false)
  mortgagePayoffYear Int?

  // For Healthcare (handled separately but can track here too)
  includesMedicare  Boolean     @default(false)

  isActive          Boolean     @default(true)
  notes             String?     @db.Text
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  // Relations
  retirementPlan    RetirementPlan @relation(fields: [retirementPlanId], references: [id], onDelete: Cascade)

  @@index([retirementPlanId])
  @@index([category])
  @@index([priority])
  @@map("retirement_expenses")
}

model SocialSecurityBenefit {
  id                String      @id @default(cuid())
  retirementPlanId  String

  // Beneficiary
  owner             String      @default("primary") // primary, spouse

  // Current Earnings Record
  currentPIA        Float?      // Primary Insurance Amount at FRA (from SSA)
  estimatedPIA      Float?      // Estimated PIA if not available

  // Earning History
  yearsOfEarnings   Int         @default(35)
  averageIndexedMonthlyEarnings Float? // AIME
  highestEarningsYears Json?    // Array of highest 35 years

  // Key Ages
  earliestClaimAge  Int         @default(62)
  fullRetirementAge Int         @default(67) // 66, 66+2mo, 67, etc.
  maxClaimAge       Int         @default(70)

  // Claiming Strategy
  plannedClaimAge   Int?        // When they plan to claim
  claimingStrategy  String      @default("optimal") // early, fra, delayed, optimal, file_suspend, restricted_application

  // Benefit Amounts
  benefitAtEarly    Float?      // Estimated benefit at 62
  benefitAtFRA      Float?      // Estimated benefit at FRA
  benefitAtMax      Float?      // Estimated benefit at 70

  // Spousal Benefits
  spousalBenefitEligible Boolean @default(false)
  spousalBenefitAmount Float?

  // Survivor Benefits
  survivorBenefitAmount Float?

  // Adjustments
  expectedCOLA      Float       @default(2.5) // Expected COLA %

  // Earnings Test
  workingWhileClaiming Boolean  @default(false)
  expectedEarningsBeforeFRA Float?

  // Optimization Results
  optimalClaimAge   Int?        // Calculated optimal age
  breakEvenAge      Int?        // Age where delayed claiming pays off
  lifetimeValue     Float?      // Total lifetime benefit estimate

  lastUpdated       DateTime?
  ssaVerified       Boolean     @default(false)

  notes             String?     @db.Text
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  // Relations
  retirementPlan    RetirementPlan @relation(fields: [retirementPlanId], references: [id], onDelete: Cascade)

  @@index([retirementPlanId])
  @@index([owner])
  @@map("social_security_benefits")
}

model RetirementHealthcarePlan {
  id                String      @id @default(cuid())
  retirementPlanId  String

  // Beneficiary
  owner             String      @default("primary") // primary, spouse, both

  // Pre-Medicare (before 65)
  preMedicareStrategy String    @default("employer") // employer, cobra, aca_marketplace, private, spouse_plan, part_time_work, health_sharing

  // ACA Marketplace
  acaPlanType       String?     // bronze, silver, silver_csr, gold, platinum
  acaEstimatedPremium Float?
  acaEstimatedSubsidy Float?    // Based on income

  // COBRA
  cobraDuration     Int?        // Months of COBRA coverage
  cobraMonthlyPremium Float?

  // Employer Retiree Benefits
  hasRetireeHealthcare Boolean  @default(false)
  retireeBenefitValue Float?

  // Medicare (65+)
  medicarePartAEligible Boolean @default(true)
  medicarePartAPremium Float    @default(0) // Usually $0 if 40+ quarters

  medicarePartBPremium Float    @default(174.70) // 2024 standard premium
  medicarePartBIRMAA Float      @default(0) // Income-related adjustment

  // Medicare Plans
  medicarePlanType  String      @default("advantage") // original_medigap, advantage, none

  // Medigap
  medigapPlanLetter String?     // A, B, C, D, F, G, K, L, M, N
  medigapPremium    Float?

  // Medicare Advantage
  advantagePlanType String?     // hmo, ppo, pffs, snp
  advantagePremium  Float?      // Often $0
  advantageOOPMax   Float?

  // Part D
  partDPremium      Float       @default(55.50) // 2024 avg
  partDIRMAA        Float       @default(0)

  // Long-term Care
  hasLTCI           Boolean     @default(false)
  ltciDailyBenefit  Float?
  ltciBenefitPeriod Int?        // Years
  ltciEliminationPeriod Int?    // Days
  ltciInflationProtection Boolean @default(false)
  ltciAnnualPremium Float?

  // HSA Strategy
  hasHSA            Boolean     @default(false)
  hsaBalance        Float?
  hsaAnnualContribution Float?
  hsaInvestmentStrategy String? // cash, invested, hybrid

  // Cost Estimates by Age
  estimatedCosts    Json?       // [{age, annualCost, premiums, outOfPocket}]

  // Assumptions
  healthStatus      String      @default("average") // excellent, good, average, poor
  chronicConditions Json?       // List of conditions affecting costs

  notes             String?     @db.Text
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  // Relations
  retirementPlan    RetirementPlan @relation(fields: [retirementPlanId], references: [id], onDelete: Cascade)

  @@index([retirementPlanId])
  @@index([owner])
  @@map("retirement_healthcare_plans")
}

model WithdrawalStrategy {
  id                String      @id @default(cuid())
  retirementPlanId  String

  // Strategy Type
  name              String
  strategyType      String      @default("dynamic") // fixed_percentage, fixed_dollar, dynamic, guardrails, bucket, floor_ceiling, endowment
  isPrimary         Boolean     @default(false)

  // Fixed Percentage Rules
  initialWithdrawalRate Float   @default(4.0) // The "4% rule"
  annualAdjustment  String      @default("inflation") // inflation, fixed, real_return, none

  // Fixed Dollar Rules
  fixedAnnualAmount Float?

  // Dynamic Rules (Guyton-Klinger, etc.)
  prosperityRule    Boolean     @default(false)
  prosperityThreshold Float?    // Portfolio gain % to trigger increase
  capitalPreservationRule Boolean @default(false)
  capitalPreservationThreshold Float? // Withdrawal rate ceiling
  withdrawalCeiling Float?      // Max withdrawal rate %
  withdrawalFloor   Float?      // Min withdrawal rate %

  // Guardrails (Vanguard Dynamic Spending)
  upperGuardrail    Float?      // % above which to increase spending
  lowerGuardrail    Float?      // % below which to decrease spending
  ceilingAdjustment Float?      // Max spending increase %
  floorAdjustment   Float?      // Max spending decrease %

  // Bucket Strategy
  buckets           Json?       // [{name, years, allocation, amount}]
  refillStrategy    String?     // annual, trigger_based, opportunistic

  // Account Withdrawal Order
  withdrawalOrder   Json?       // ["taxable", "tax_deferred", "tax_free"] or custom
  taxBracketAwareness Boolean   @default(true)
  rothConversionIntegration Boolean @default(false)

  // Required Minimum Distributions
  handleRMDs        String      @default("satisfy_first") // satisfy_first, reinvest_excess, charitable_qcd

  // Social Security Integration
  ssBridgeStrategy  Boolean     @default(false) // Higher withdrawals before SS starts

  // Monte Carlo Results
  successRate       Float?      // % of simulations successful
  medianEndingBalance Float?
  worstCaseEndingBalance Float?
  bestCaseEndingBalance Float?

  // Backtested Results
  historicalSuccessRate Float?
  worstStartYear    Int?        // Worst historical start year

  notes             String?     @db.Text
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  // Relations
  retirementPlan    RetirementPlan @relation(fields: [retirementPlanId], references: [id], onDelete: Cascade)

  @@index([retirementPlanId])
  @@index([strategyType])
  @@map("withdrawal_strategies")
}

model RothConversionPlan {
  id                String      @id @default(cuid())
  retirementPlanId  String

  // Strategy
  name              String      @default("Roth Conversion Strategy")
  strategyType      String      @default("fill_bracket") // none, fill_bracket, fixed_amount, before_ss, before_rmd, aggressive, backdoor, mega_backdoor

  // Target Tax Bracket
  targetBracket     Float?      // Fill up to X% bracket (e.g., 22%)
  targetAGI         Float?      // Or fill up to specific AGI

  // Fixed Amount Strategy
  annualConversionAmount Float? // Convert $X per year

  // Timing
  startYear         Int?
  startAge          Int?
  endYear           Int?
  endAge            Int?

  // Conversion Window
  yearsBeforeSS     Int?        // Convert X years before SS
  yearsBeforeRMD    Int?        // Convert X years before RMDs

  // Conversion Schedule
  conversionSchedule Json?      // [{year, amount, fromAccount, taxCost, cumulativeConverted}]

  // Tax Impact Analysis
  totalToConvert    Float?
  totalTaxCost      Float?
  estimatedTaxSavings Float?    // Lifetime tax savings vs no conversion
  breakEvenYears    Int?        // Years until conversions pay off

  // Constraints
  maxAnnualTaxBill  Float?      // Don't exceed this tax bill
  avoidIRMAA        Boolean     @default(true) // Stay below IRMAA thresholds
  avoidNIIT         Boolean     @default(false) // Stay below NIIT threshold
  preserveACASubsidy Boolean    @default(false)

  // Current Progress
  totalConverted    Float       @default(0)
  lastConversionYear Int?
  lastConversionAmount Float?

  notes             String?     @db.Text
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  // Relations
  retirementPlan    RetirementPlan @relation(fields: [retirementPlanId], references: [id], onDelete: Cascade)

  @@index([retirementPlanId])
  @@index([strategyType])
  @@map("roth_conversion_plans")
}

model RetirementScenario {
  id                String      @id @default(cuid())
  retirementPlanId  String

  // Scenario Details
  name              String
  description       String?
  type              String      @default("what_if") // base_case, optimistic, pessimistic, what_if, stress_test
  isBaseCase        Boolean     @default(false)

  // Overrides (null means use plan default)
  retirementAge     Int?
  spouseRetirementAge Int?
  lifeExpectancy    Int?

  annualExpenses    Float?
  retirementIncome  Float?

  // Market Assumptions
  equityReturn      Float?
  bondReturn        Float?
  inflationRate     Float?

  // Social Security
  ssClaimAge        Int?
  spouseSSClaimAge  Int?
  ssReductionPct    Float?      // For stress testing SS cuts

  // One-time Events
  events            Json?       // [{year, type, amount, description}] e.g., inheritance, home sale, large expense

  // Results
  projectionResults Json?       // Year-by-year projection
  successRate       Float?      // Monte Carlo success rate
  retirementReadinessScore Int? // 0-100 score

  // Gap Analysis
  incomeGap         Float?      // Annual shortfall if any
  savingsGap        Float?      // Additional savings needed
  yearsOfSavingsGap Int?        // How many years short

  // Key Metrics
  portfolioAtRetirement Float?
  portfolioAt80     Float?
  portfolioAt90     Float?
  portfolioDepletion Int?       // Age when money runs out (if applicable)
  legacyAmount      Float?      // Expected inheritance

  // Comparison to Base
  vsBaseCase        Json?       // {successRateDiff, endingBalanceDiff, etc.}

  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  // Relations
  retirementPlan    RetirementPlan @relation(fields: [retirementPlanId], references: [id], onDelete: Cascade)

  @@unique([retirementPlanId, name])
  @@index([retirementPlanId])
  @@index([type])
  @@map("retirement_scenarios")
}

model RetirementProjection {
  id                String      @id @default(cuid())
  retirementPlanId  String

  // Projection Metadata
  calculatedAt      DateTime    @default(now())
  projectionType    String      @default("monte_carlo") // deterministic, monte_carlo, historical
  scenarioId        String?

  // Input Summary
  inputSnapshot     Json        // Snapshot of all inputs at calculation time

  // Year-by-Year Detail
  yearlyProjection  Json        // [{year, age, spouseAge, portfolioValue, income, expenses, taxes, withdrawals, contributions, ssIncome, pensionIncome, otherIncome, healthcareCosts, legacyValue}]

  // Monte Carlo Results
  monteCarloRuns    Int?
  successRate       Float?      // % of runs that didn't deplete
  failureRate       Float?

  // Distribution of Outcomes
  percentile10      Float?      // Worst 10%
  percentile25      Float?
  percentile50      Float?      // Median
  percentile75      Float?
  percentile90      Float?      // Best 10%

  // Key Ages Analysis
  portfolioAtRetirement Float?
  portfolioAt70     Float?
  portfolioAt80     Float?
  portfolioAt90     Float?
  portfolioAt100    Float?

  // Depletion Analysis
  depletionAge      Int?        // Age when portfolio depletes (if <100%)
  medianDepletionAge Int?

  // Income Analysis
  totalLifetimeIncome Float?
  totalSSBenefits   Float?
  totalPensionBenefits Float?
  totalWithdrawals  Float?

  // Expense Analysis
  totalLifetimeExpenses Float?
  totalHealthcareCosts Float?
  totalTaxes        Float?

  // Legacy Analysis
  expectedLegacy    Float?
  legacyProbability Float?      // % chance of leaving target legacy

  // Tax Efficiency
  totalTaxesPaid    Float?
  effectiveTaxRate  Float?
  rothConversionBenefit Float?

  // Recommendations
  recommendations   Json?       // [{priority, category, title, description, impact}]

  // Assumptions Used
  assumptions       Json        // All assumptions used in this projection

  // Relations
  retirementPlan    RetirementPlan @relation(fields: [retirementPlanId], references: [id], onDelete: Cascade)

  @@index([retirementPlanId])
  @@index([calculatedAt])
  @@index([projectionType])
  @@map("retirement_projections")
}

model RetirementMilestone {
  id                String      @id @default(cuid())
  retirementPlanId  String

  // Milestone Details
  name              String
  description       String?
  category          String      // savings, age, income, expense, lifestyle, estate

  // Target
  targetType        String      // age, date, amount, percentage
  targetAge         Int?
  targetDate        DateTime?
  targetAmount      Float?
  targetPercentage  Float?

  // Current Progress
  currentValue      Float?
  progressPct       Float?      // 0-100

  // Status
  status            String      @default("not_started") // not_started, in_progress, on_track, at_risk, achieved, missed
  achievedDate      DateTime?

  // Priority
  priority          Int         @default(5) // 1-10
  isKeyMilestone    Boolean     @default(false)

  // Alerts
  alertThreshold    Float?      // Alert if progress falls below
  alertEnabled      Boolean     @default(true)
  lastAlertSent     DateTime?

  // Dependencies
  dependsOnMilestones String[]  // Other milestone IDs this depends on

  notes             String?     @db.Text
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  // Relations
  retirementPlan    RetirementPlan @relation(fields: [retirementPlanId], references: [id], onDelete: Cascade)

  @@index([retirementPlanId])
  @@index([status])
  @@index([category])
  @@map("retirement_milestones")
}

//=====================
// FEATURE VOTING
//=====================

model FeatureVote {
  id              String    @id @default(cuid())
  userId          String
  featureId       String    // ID of the feature (e.g., "habit-tracker", "ai-coach")
  featureName     String    // Display name of the feature
  voted           Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, featureId]) // Each user can only vote once per feature
  @@index([userId])
  @@index([featureId])
  @@map("feature_votes")
}

//=====================
// FEATURE WAITLIST
//=====================

model FeatureWaitlist {
  id              String    @id @default(cuid())
  userId          String
  feature         String    // Feature name (e.g., "resume_builder", "courses")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, feature]) // Each user can only join waitlist once per feature
  @@index([userId])
  @@index([feature])
  @@map("feature_waitlist")
}

//=====================
// EDUCATION PLANNING MODULE
// Most Advanced Education ROI & Planning System
//=====================

// School & Degree Data Repository
model School {
  id                    String    @id @default(cuid())
  name                  String
  city                  String?
  state                 String?
  country               String    @default("USA")
  type                  String    // public, private, for-profit

  // Basic Cost Data
  tuitionInState        Float?    // Annual in-state tuition
  tuitionOutOfState     Float?    // Annual out-of-state tuition
  fees                  Float?    // Annual fees
  roomAndBoard          Float?    // Annual room & board
  books                 Float?    // Annual books/supplies
  otherExpenses         Float?    // Transportation, personal, etc.

  // Inflation Assumptions
  tuitionInflationRate  Float     @default(0.03) // 3% default
  coaInflationRate      Float     @default(0.025) // 2.5% default

  // Metadata
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Relations
  degreePrograms        DegreeProgram[]
  degreeAnalyses        DegreeAnalysis[]

  @@index([name])
  @@index([state])
  @@index([type])
  @@map("schools")
}

// Degree Program with Career Outcome Data
model DegreeProgram {
  id                    String    @id @default(cuid())
  schoolId              String

  // Program Details
  degreeType            String    // bachelors, masters, jd, md, mba, phd, etc.
  major                 String    // Computer Science, Law, Business, etc.
  programLength         Int       // Years

  // Career Outcome Data
  startingSalary        Float?    // Median starting salary
  salary25Percentile    Float?
  salary75Percentile    Float?
  midCareerSalary       Float?    // 10 years out
  salaryGrowthRate      Float?    // Annual growth rate

  // Employment Data
  jobPlacementRate      Float?    // % employed within 6 months
  underemploymentRate   Float?    // % working outside field
  jobGrowthRate         Float?    // Industry job growth rate

  // Alumni Network Impact Score (ANIS)
  anisScore             Float     @default(1.0) // 0.8-1.5 range
  anisJobFactor         Float     @default(1.0)
  anisSalaryAlpha       Float     @default(0.0)
  anisGrowthBeta        Float     @default(0.0)
  anisUnderemployGamma  Float     @default(0.0)

  // Network Metrics
  alumniCount           Int?
  alumniInTargetRoles   Int?
  alumniLeadershipPct   Float?    // % in leadership roles
  networkDensityScore   Float?    // Geographic & industry reach
  brandPremiumScore     Float?    // Market perception

  // Degree Type Category for ANIS weighting
  networkImportance     String    @default("medium") // high, medium, low

  // Follow-On Program Access Score (FPAS)
  // Scores for admission to graduate/professional programs
  fpasLawSchool         Float?    @default(1.0) // 0.5-2.0 multiplier for law school admission
  fpasMedSchool         Float?    @default(1.0) // 0.5-2.0 multiplier for med school admission
  fpasMBA               Float?    @default(1.0) // 0.5-2.0 multiplier for MBA programs
  fpasPhD               Float?    @default(1.0) // 0.5-2.0 multiplier for PhD programs
  fpasMasters           Float?    @default(1.0) // 0.5-2.0 multiplier for Masters programs

  // FPAS Details (JSON: acceptance rates, feeder status, etc.)
  fpasMetrics           String?   // {law_t14_rate, med_match_rate, mba_m7_rate, etc.}

  // Metadata
  lastUpdated           DateTime  @default(now())
  dataSource            String?   // BLS, Payscale, LinkedIn, etc.
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Relations
  school                School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  degreeAnalyses        DegreeAnalysis[]

  @@index([schoolId])
  @@index([degreeType])
  @@index([major])
  @@index([networkImportance])
  @@map("degree_programs")
}

// Student Profile for Education Planning
model StudentProfile {
  id                    String    @id @default(cuid())
  userId                String

  // Student Info
  studentName           String
  currentAge            Int
  enrollmentYear        Int       // Year they'll start college
  graduationYear        Int       // Expected graduation year

  // Location & Preferences
  currentState          String?
  preferredRegion       String?   // For job market analysis

  // Financial Background
  householdIncome       Float?
  expectedFamilyContribution Float?

  // Goals & Career Targets
  targetIndustry        String?
  targetRole            String?
  targetSalaryRange     String?   // JSON: {min, max}

  // Long-Term Educational Goals (Follow-On Programs)
  hasLongTermGoal       Boolean   @default(false)
  longTermGoalType      String?   // jd, md, mba, phd, masters, etc.
  targetProgramTier     String?   // top_10, top_25, top_50, any
  targetGPA             Float?    // Target GPA for grad school
  targetTestScore       String?   // JSON: {test_type, target_score}

  // Life Goals Integration (JSON)
  linkedGoalIds         String?   // Array of Goal IDs

  // Metadata
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Relations
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  financingAccounts     EducationFinancingAccount[]
  degreeAnalyses        DegreeAnalysis[]
  degreeComparisons     DegreeComparison[]
  educationDocuments    EducationDocument[]

  @@index([userId])
  @@map("student_profiles")
}

// Education Financing Accounts (529, Custodial, Savings)
model EducationFinancingAccount {
  id                    String    @id @default(cuid())
  studentProfileId      String

  // Account Details
  accountType           String    // 529, custodial, savings, brokerage
  accountName           String
  currentBalance        Float
  monthlyContribution   Float     @default(0)
  annualReturnRate      Float     @default(0.06) // 6% default

  // Prioritization for Waterfall
  priority              Int       @default(1) // Lower = used first

  // Metadata
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Relations
  studentProfile        StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  @@index([studentProfileId])
  @@index([accountType])
  @@map("education_financing_accounts")
}

// Degree Analysis (Degree Decision Matrix)
model DegreeAnalysis {
  id                    String    @id @default(cuid())
  userId                String
  studentProfileId      String
  schoolId              String
  degreeProgramId       String?   // Null if custom/manual entry

  // Custom Overrides (if not using DegreeProgram)
  customSchoolName      String?
  customDegreeName      String?
  customDegreeType      String?
  customProgramLength   Int?

  // Cost Inputs
  tuition               Float
  fees                  Float
  roomBoard             Float
  books                 Float
  otherExpenses         Float
  tuitionInflation      Float     @default(0.03)
  coaInflation          Float     @default(0.025)

  // Financial Aid
  scholarships          Float     @default(0) // Annual scholarships
  grants                Float     @default(0) // Annual grants

  // Career Inputs
  expectedStartSalary   Float
  expectedSalaryGrowth  Float
  expectedJobPlacementRate Float
  targetRegion          String?

  // Network Preference
  networkPriority       String    @default("medium") // low, medium, high

  // === CALCULATED RESULTS ===

  // Cost of Attendance Results
  totalCostOfAttendance Float     // Total 4-year cost
  yearlyBreakdown       String?   // JSON array of yearly costs

  // Financing Waterfall Results
  total529Used          Float     @default(0)
  totalCustodialUsed    Float     @default(0)
  totalSavingsUsed      Float     @default(0)
  totalCashFlowUsed     Float     @default(0)
  totalLoansNeeded      Float     @default(0)
  loanBreakdown         String?   // JSON: yearly loan amounts

  // Debt Projections
  monthlyPayment        Float?
  paybackPeriodMonths   Int?
  totalInterestPaid     Float?
  debtToIncomeRatio     Float?    // At graduation

  // Career Outcomes (ANIS-Adjusted)
  adjustedStartSalary   Float?
  adjustedSalaryGrowth  Float?
  adjustedPlacementRate Float?
  adjustedUnderemploymentRate Float?

  // ROI Calculations
  paybackPeriodYears    Float?
  lifetimeNetValue      Float?    // NPV of incremental earnings minus debt
  npvIncrementalEarnings Float?

  // Scenario Analysis (JSON)
  conservativeScenario  String?   // {roi, payback, netValue}
  baseScenario          String?
  optimisticScenario    String?

  // Goal Alignment
  goalAlignmentScore    Float?    // 0-100
  goalImpactAnalysis    String?   // JSON: impact on each goal

  // AI Analysis
  aiSummary             String?   // Plain language explanation
  aiWarnings            String?   // JSON array of warnings
  aiSuggestions         String?   // JSON array of suggestions
  riskLevel             String?   // low, medium, high, extreme

  // Metadata
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Relations
  user                  User      @relation(fields: [userId], references: [id])
  studentProfile        StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  school                School    @relation(fields: [schoolId], references: [id])
  degreeProgram         DegreeProgram? @relation(fields: [degreeProgramId], references: [id])
  comparisonEntries     DegreeComparisonEntry[]

  @@index([userId])
  @@index([studentProfileId])
  @@index([schoolId])
  @@index([degreeProgramId])
  @@map("degree_analyses")
}

// Degree Comparison (multi-degree comparison engine)
model DegreeComparison {
  id                    String    @id @default(cuid())
  userId                String
  studentProfileId      String

  // Comparison Name
  name                  String    @default("Degree Comparison")

  // User Preferences / Weights
  debtWeight            Float     @default(0.25)  // 25%
  earningsWeight        Float     @default(0.25)
  paybackWeight         Float     @default(0.20)
  riskWeight            Float     @default(0.15)
  goalAlignmentWeight   Float     @default(0.15)

  // AI Recommendation
  aiRecommendation      String?   // Plain language: "Choose X if Y, choose Z if..."
  topChoice             String?   // degreeAnalysisId of recommended option

  // Metadata
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Relations
  user                  User      @relation(fields: [userId], references: [id])
  studentProfile        StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  entries               DegreeComparisonEntry[]

  @@index([userId])
  @@index([studentProfileId])
  @@map("degree_comparisons")
}

// Junction table for comparison entries
model DegreeComparisonEntry {
  id                    String    @id @default(cuid())
  comparisonId          String
  degreeAnalysisId      String

  // Ranking & Scores
  overallRank           Int?      // 1 = best
  weightedScore         Float?    // Combined weighted score

  createdAt             DateTime  @default(now())

  // Relations
  comparison            DegreeComparison @relation(fields: [comparisonId], references: [id], onDelete: Cascade)
  degreeAnalysis        DegreeAnalysis @relation(fields: [degreeAnalysisId], references: [id], onDelete: Cascade)

  @@unique([comparisonId, degreeAnalysisId])
  @@index([comparisonId])
  @@index([degreeAnalysisId])
  @@map("degree_comparison_entries")
}

// Document Uploads (Financial Aid Letters, 529 Statements, etc.)
model EducationDocument {
  id                    String    @id @default(cuid())
  userId                String
  studentProfileId      String?

  // Document Info
  fileName              String
  fileType              String    // pdf, png, jpg
  fileSize              Int       // bytes
  storagePath           String    // Azure Blob Storage path

  // Document Type
  documentType          String    // aid_letter, scholarship_letter, 529_statement, school_costs

  // Extracted Data (JSON)
  extractedData         String?   // OCR + structured extraction results

  // Processing Status
  processingStatus      String    @default("pending") // pending, processing, completed, failed
  extractedAt           DateTime?

  // Metadata
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Relations
  user                  User      @relation(fields: [userId], references: [id])
  studentProfile        StudentProfile? @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([studentProfileId])
  @@index([documentType])
  @@index([processingStatus])
  @@map("education_documents")
}
