  phone             String?
  location          String?
  linkedInUrl       String?
  githubUrl         String?
  portfolioUrl      String?
  websiteUrl        String?

  // Professional Summary
  summary           String?   @db.Text

  // Structured Data (JSON arrays)
  experience        Json?     // Array of work experiences with company, title, dates, bullets
  education         Json?     // Array of education entries
  skills            Json?     // Categorized skills (technical, soft, languages, etc.)
  certifications    Json?     // Array of certifications
  projects          Json?     // Array of notable projects
  awards            Json?     // Array of awards/achievements
  publications      Json?     // Array of publications
  languages         Json?     // Language proficiencies
  customSections    Json?     // User-defined custom sections

  // Job Targeting
  targetJobTitle    String?   // The job title this resume targets
  targetJobDescription String? @db.Text // The job description for AI optimization
  targetCompany     String?   // Target company name
  keywords          String[]  // ATS-optimized keywords

  // AI Generation Metadata
  aiGenerated       Boolean   @default(false)
  aiModel           String?   // Model used for generation
  aiPrompt          String?   @db.Text // Prompt used for generation
  atsScore          Int?      // ATS compatibility score 0-100
  lastAnalyzedAt    DateTime?

  // Versioning
  version           Int       @default(1)
  parentResumeId    String?   // Reference to parent resume if this is a version

  // Export Info
  pdfUrl            String?   // URL to generated PDF
  docxUrl           String?   // URL to generated DOCX
