model WearableConnection {
  id                String    @id @default(cuid())
  userId            String
  provider          String    // apple_health, google_fit, fitbit, garmin, samsung_health, oura, whoop
  deviceType        String?   // watch, ring, band, scale, etc.
  deviceModel       String?   // Apple Watch Series 9, Fitbit Charge 6, etc.
  deviceName        String?   // User's custom device name
  accessToken       String?   @db.Text
  refreshToken      String?   @db.Text
  expiresAt         DateTime?
  scope             String?   // Permissions granted
  lastSyncedAt      DateTime?
  status            String    @default("active") // active, error, expired, disconnected
  syncFrequency     String    @default("hourly") // realtime, hourly, daily, manual
  dataTypes         String[]  // heart_rate, steps, sleep, calories, etc.
  userId_external   String?   // External user ID from provider
  metadata          Json?     // Provider-specific data
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  metrics           WearableMetric[]
  syncLogs          WearableSyncLog[]

  @@unique([userId, provider]) // One connection per provider per user
  @@index([userId])
  @@index([provider])
  @@index([status])
  @@map("wearable_connections")
}

model WearableMetric {
  id                  String              @id @default(cuid())
  userId              String
  connectionId        String
  metricType          String              // steps, heart_rate, calories, sleep, distance, etc.
  value               Float
  unit                String              // count, bpm, kcal, minutes, meters, etc.
  timestamp           DateTime            // When the metric was recorded
  startTime           DateTime?           // For duration metrics (sleep, workout)
  endTime             DateTime?           // For duration metrics
  metadata            Json?               // Additional data (e.g., sleep stages, workout type)
  source              String              // apple_health, google_fit, fitbit, etc.
  sourceRecordId      String?             // External record ID for deduplication
  confidence          Float?              // Data quality/confidence score (0-1)
  isManualEntry       Boolean             @default(false)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  // Relations
  user                User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  connection          WearableConnection  @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@unique([connectionId, sourceRecordId]) // Prevent duplicates from same source
  @@index([userId])
  @@index([connectionId])
  @@index([metricType])
  @@index([timestamp])
  @@map("wearable_metrics")
}

model WearableSyncLog {
  id                String              @id @default(cuid())
  connectionId      String
  syncStartedAt     DateTime            @default(now())
  syncCompletedAt   DateTime?
  status            String              // success, partial, failed, in_progress
  recordsSynced     Int                 @default(0)
  recordsFailed     Int                 @default(0)
  errorMessage      String?             @db.Text
  dataTypes         String[]            // Which data types were synced
  dateRangeStart    DateTime?           // Start of synced period
  dateRangeEnd      DateTime?           // End of synced period
  metadata          Json?

  // Relations
  connection        WearableConnection  @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([connectionId])
  @@index([syncStartedAt])
  @@index([status])
  @@map("wearable_sync_logs")
}

