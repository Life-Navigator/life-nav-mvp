// LifeNavigator Security-Enhanced Database Schema
// NSA Commercial Solutions for Classified (CSfC) Compliant
// Encryption: AES-256-GCM, RSA-4096, SHA-384
// Row-Level Security (RLS) Enabled

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters", "postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgcrypto, "uuid-ossp"]
}

//=====================
// ENCRYPTION KEY MANAGEMENT
//=====================

model EncryptionKey {
  id              String   @id @default(cuid())
  keyId           String   @unique @default(uuid())
  keyType         String   // master, field, document, backup
  algorithm       String   @default("AES-256-GCM") // NSA Suite B approved
  keyMaterial     String?  @db.Text // Encrypted with master key
  publicKey       String?  @db.Text // For RSA-4096
  privateKey      String?  @db.Text // Encrypted storage
  keyVersion      Int      @default(1)
  rotatedFrom     String?  // Previous key ID
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  rotatedAt       DateTime?
  expiresAt       DateTime // Key rotation schedule
  lastUsedAt      DateTime?
  createdBy       String
  
  @@index([keyType])
  @@index([isActive])
  @@map("encryption_keys")
}

model EncryptedFieldMetadata {
  id              String   @id @default(cuid())
  tableName       String
  columnName      String
  encryptionKeyId String
  encryptionType  String   // field_level, column_level, transparent
  algorithm       String   @default("AES-256-GCM")
  ivLength        Int      @default(16) // Initialization vector
  tagLength       Int      @default(16) // Authentication tag
  isSearchable    Boolean  @default(false) // Deterministic vs randomized
  createdAt       DateTime @default(now())
  
  @@unique([tableName, columnName])
  @@map("encrypted_field_metadata")
}

//=====================
// ROW LEVEL SECURITY POLICIES
//=====================

model AccessPolicy {
  id              String   @id @default(cuid())
  policyName      String   @unique
  tableName       String
  operation       String   // SELECT, INSERT, UPDATE, DELETE
  roleRequired    String?  // admin, user, viewer
  expression      String   @db.Text // PostgreSQL RLS expression
  isEnabled       Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([tableName])
  @@map("access_policies")
}

model UserAccessControl {
  id              String   @id @default(cuid())
  userId          String
  resourceType    String   // table name or resource type
  resourceId      String   // specific record ID
  permission      String   // read, write, delete, share
  grantedBy       String
  grantedAt       DateTime @default(now())
  expiresAt       DateTime?
  reason          String?
  
  @@unique([userId, resourceType, resourceId, permission])
  @@index([userId])
  @@index([resourceType, resourceId])
  @@map("user_access_controls")
}

//=====================
// ENHANCED USER MODEL WITH ENCRYPTION
//=====================

model User {
  id                    String                  @id @default(cuid())
  email                 String                  @unique
  emailHash             String                  @unique // For searching while encrypted
  emailEncrypted        Bytes                   // AES-256-GCM encrypted
  emailIv               Bytes                   // Initialization vector
  emailTag              Bytes                   // Authentication tag
  name                  String?
  nameEncrypted         Bytes?                  // Encrypted PII
  password              String?                 @db.Text // Argon2id hashed
  passwordSalt          String?
  passwordKeyDerivation String?                 @default("argon2id")
  emailVerified         DateTime?
  image                 String?
  role                  String                  @default("user")
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  setupCompleted        Boolean                 @default(false)
  lastLogin             DateTime?
  isActive              Boolean                 @default(true)
  failedLoginAttempts   Int                     @default(0)
  lockedUntil           DateTime?
  mfaEnabled            Boolean                 @default(false)
  mfaSecret             Bytes?                  // Encrypted TOTP secret
  mfaBackupCodes        Bytes?                  // Encrypted backup codes
  encryptionKeyId       String?                 // User-specific encryption key
  
  // Security fields
  securityLevel         String                  @default("standard") // standard, elevated, maximum
  dataClassification    String                  @default("internal") // public, internal, confidential, secret
  accessTier            String                  @default("basic") // basic, premium, enterprise
  
  // Relations
  accounts              Account[]
  sessions              Session[]
  goals                 Goal[]
  riskAssessments       RiskAssessment[]
  financialAccounts     FinancialAccount[]
  financialTransactions Transaction[]
  financialAssets       Asset[]
  financialGoals        FinancialGoal[]
  healthRecords         HealthRecord[]
  healthMetrics         HealthMetric[]
  educationRecords      EducationRecord[]
  educationCourses      EducationCourse[]
  careerProfiles        CareerProfile[]
  careerApplications    JobApplication[]
  documents             Document[]
  notifications         Notification[]
  preferences           UserPreference?
  securityAuditLogs     SecurityAuditLog[]
  revokedTokens         RevokedToken[]
  userDevices           UserDevice[]
  integrations          UserIntegration[]
  accessControls        UserAccessControl[]
  cryptoOperations      CryptoOperation[]
  
  @@index([email])
  @@index([emailHash])
  @@index([createdAt])
  @@index([securityLevel])
  @@map("users")
}

//=====================
// CRYPTOGRAPHIC OPERATIONS AUDIT
//=====================

model CryptoOperation {
  id              String   @id @default(cuid())
  userId          String?
  operationType   String   // encrypt, decrypt, sign, verify, hash
  algorithm       String   // AES-256-GCM, RSA-4096, SHA-384
  keyId           String?
  tableName       String?
  recordId        String?
  fieldName       String?
  success         Boolean
  errorMessage    String?
  performanceMs   Int?     // Operation duration
  ipAddress       String?
  userAgent       String?
  createdAt       DateTime @default(now())
  
  user            User?    @relation(fields: [userId], references: [id])
  
  @@index([userId])
  @@index([operationType])
  @@index([createdAt])
  @@map("crypto_operations")
}

//=====================
// FINANCIAL MODELS WITH ENCRYPTION
//=====================

model FinancialAccount {
  id                    String        @id @default(cuid())
  userId                String
  name                  String
  type                  String        // checking, savings, investment, credit, loan, crypto
  subtype               String?
  institution           String
  institutionEncrypted  Bytes?        // Encrypted institution name
  accountNumber         Bytes?        // AES-256-GCM encrypted
  accountNumberIv       Bytes?        // IV for account number
  accountNumberTag      Bytes?        // Auth tag
  accountNumberHash     String?       // For duplicate checking
  accountNumberLast4    String?       // For display
  routingNumber         Bytes?        // Encrypted
  routingNumberIv       Bytes?
  routingNumberTag      Bytes?
  balance               Float
  balanceEncrypted      Bytes?        // For high-security accounts
  availableBalance      Float?
  creditLimit           Float?
  interestRate          Float?
  currency              String        @default("USD")
  isActive              Boolean       @default(true)
  isPrimary             Boolean       @default(false)
  encryptionKeyId       String?       // Account-specific key
  lastSynced            DateTime      @default(now())
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  notes                 String?
  integrationId         String?
  
  // Row Level Security
  ownerUserId           String        // For RLS policies
  sharedWith            String[]      // User IDs with access
  accessLevel           String        @default("owner") // owner, editor, viewer
  
  // Relations
  user                  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions          Transaction[]
  
  @@unique([userId, name])
  @@index([userId])
  @@index([type])
  @@index([ownerUserId])
  @@map("financial_accounts")
}

model Transaction {
  id                    String           @id @default(cuid())
  userId                String
  accountId             String
  amount                Float
  amountEncrypted       Bytes?           // For sensitive amounts
  currency              String           @default("USD")
  description           String
  descriptionEncrypted  Bytes?           // Encrypted description
  category              String
  subcategory           String?
  date                  DateTime
  type                  String           // income, expense, transfer, investment
  status                String           @default("completed")
  isRecurring           Boolean          @default(false)
  recurringId           String?
  merchantName          String?
  merchantNameEncrypted Bytes?           // Encrypted merchant
  merchantCategory      String?
  reference             String?
  referenceEncrypted    Bytes?           // Encrypted reference
  notes                 Bytes?           // Always encrypted
  notesIv               Bytes?
  notesTag              Bytes?
  tags                  String[]
  locationLat           Float?
  locationLong          Float?
  encryptionKeyId       String?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  
  // Row Level Security
  ownerUserId           String
  visibility            String           @default("private") // private, shared, public
  
  // Relations
  user                  User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  account               FinancialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([accountId])
  @@index([date])
  @@index([category])
  @@index([ownerUserId])
  @@map("transactions")
}

//=====================
// HEALTH MODELS WITH MAXIMUM ENCRYPTION (HIPAA)
//=====================

model HealthRecord {
  id                    String   @id @default(cuid())
  userId                String
  type                  String   // medical_visit, procedure, diagnosis, medication
  category              String?
  
  // All health data encrypted at rest
  providerNameEncrypted Bytes?
  providerNameIv        Bytes?
  providerNameTag       Bytes?
  facilityNameEncrypted Bytes?
  diagnosisEncrypted    Bytes?
  diagnosisIv           Bytes?
  diagnosisTag          Bytes?
  treatmentEncrypted    Bytes?
  prescriptionEncrypted Bytes?   // Medication details
  prescriptionIv        Bytes?
  prescriptionTag       Bytes?
  
  date                  DateTime
  title                 String   // Generic title, not encrypted
  followUpDate          DateTime?
  attachmentUrls        Bytes[]  // Encrypted URLs
  notesEncrypted        Bytes?
  notesIv               Bytes?
  notesTag              Bytes?
  isConfidential        Boolean  @default(true)
  encryptionKeyId       String   // Mandatory for health records
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  // HIPAA Compliance
  accessLog             Json[]   // Who accessed and when
  consentId             String?  // Link to consent record
  dataRetentionDate     DateTime // When to purge
  
  // Row Level Security
  ownerUserId           String
  authorizedUsers       String[] // Healthcare providers with access
  emergencyAccess       Boolean  @default(false)
  
  // Relations
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([date])
  @@index([type])
  @@index([ownerUserId])
  @@map("health_records")
}

//=====================
// DOCUMENT MODELS WITH ENCRYPTION
//=====================

model Document {
  id                 String   @id @default(cuid())
  userId             String
  title              String   // Not encrypted for searching
  titleEncrypted     Bytes?   // Encrypted version
  description        String?
  category           String   // financial, health, education, career, legal
  subcategory        String?
  
  // File encryption
  fileUrl            String   // URL to encrypted blob
  fileKey            Bytes    // AES-256 key for file
  fileIv             Bytes    // Initialization vector
  fileTag            Bytes    // Authentication tag
  fileHash           String   // SHA-384 hash for integrity
  
  fileName           String
  fileNameEncrypted  Bytes?
  fileType           String
  mimeType           String?
  fileSize           Int
  fileSizeEncrypted  Int?     // Size of encrypted file
  
  tags               String[]
  encryptionKeyId    String   // Document encryption key
  encryptionAlgo     String   @default("AES-256-GCM")
  isDoubleEncrypted  Boolean  @default(false) // For maximum security
  
  // Metadata
  isArchived         Boolean  @default(false)
  expiresAt          DateTime?
  ocrText            Bytes?   // Encrypted OCR text
  ocrTextIv          Bytes?
  ocrTextTag         Bytes?
  
  // Row Level Security
  ownerUserId        String
  sharedWith         String[]
  shareExpiry        DateTime?
  accessPassword     String?  // Additional password protection
  
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  
  // Relations
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([category])
  @@index([ownerUserId])
  @@index([createdAt])
  @@map("documents")
}

//=====================
// RISK ASSESSMENT WITH ENCRYPTED PII
//=====================

model RiskAssessment {
  id                    String                 @id @default(cuid())
  userId                String
  assessmentType        String
  status                String                 @default("in_progress")
  completedAt           DateTime?
  expiresAt             DateTime?
  overallRiskScore      Float?
  overallRiskEncrypted  Bytes?                 // Encrypted score
  riskLevel             String?
  theta                 Float?                 // Calculated theta
  thetaEncrypted        Bytes?                 // Encrypted theta
  thetaIv               Bytes?
  thetaTag              Bytes?
  encryptionKeyId       String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  
  // Row Level Security
  ownerUserId           String
  viewableBy            String[]               // Authorized viewers
  
  // Relations
  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers               AssessmentAnswer[]
  categoryScores        RiskCategoryScore[]
  recommendations       RiskRecommendation[]
  
  @@index([userId])
  @@index([status])
  @@index([ownerUserId])
  @@index([createdAt])
  @@map("risk_assessments")
}

model AssessmentAnswer {
  id                 String              @id @default(cuid())
  assessmentId       String
  questionId         String
  answerValue        String?             // Non-sensitive answer
  answerEncrypted    Bytes?              // Sensitive answer encrypted
  answerIv           Bytes?
  answerTag          Bytes?
  answerScore        Float?
  riskImpact         Float?
  confidence         Float?
  notesEncrypted     Bytes?
  encryptionKeyId    String?
  createdAt          DateTime            @default(now())
  
  // Relations
  assessment         RiskAssessment      @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  question           AssessmentQuestion  @relation(fields: [questionId], references: [id])
  
  @@unique([assessmentId, questionId])
  @@index([assessmentId])
  @@map("assessment_answers")
}

//=====================
// GOAL SYSTEM WITH PRIVACY
//=====================

model Goal {
  id                 String           @id @default(cuid())
  userId             String
  title              String
  titleEncrypted     Bytes?           // For private goals
  description        String?
  descriptionEncrypted Bytes?         // Encrypted description
  category           GoalCategory     @relation(fields: [categoryId], references: [id])
  categoryId         String
  targetDate         DateTime?
  targetValue        Float?
  currentValue       Float?           @default(0)
  unit               String?
  priority           String           @default("medium")
  status             String           @default("active")
  isPrivate          Boolean          @default(false)
  isEncrypted        Boolean          @default(false)
  encryptionKeyId    String?
  
  // SMART goal components (potentially sensitive)
  specific           String?
  specificEncrypted  Bytes?
  measurable         String?
  achievable         String?
  relevant           String?
  timeBound          String?
  
  completedAt        DateTime?
  progress           Float            @default(0)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  
  // Row Level Security
  ownerUserId        String
  sharedWith         String[]
  visibility         String           @default("private") // private, friends, public
  
  // Relations
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  milestones         GoalMilestone[]
  benefits           GoalBenefit[]
  updates            GoalUpdate[]
  reminders          GoalReminder[]
  dependencies       GoalDependency[] @relation("DependentGoal")
  dependents         GoalDependency[] @relation("PrerequisiteGoal")
  
  @@index([userId])
  @@index([categoryId])
  @@index([status])
  @@index([ownerUserId])
  @@index([targetDate])
  @@map("goals")
}

