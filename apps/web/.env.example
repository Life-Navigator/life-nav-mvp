# =============================================================================
# Life Navigator Frontend Configuration
# =============================================================================

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
INTEGRATION_ENCRYPTION_KEY=

# Backend API
NEXT_PUBLIC_API_URL=http://localhost:8000

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/integrations/oauth/callback/google

# Microsoft OAuth (Outlook + Calendar)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=http://localhost:3000/api/integrations/oauth/callback/microsoft
SUPABASE_AZURE_CLIENT_ID=
SUPABASE_AZURE_CLIENT_SECRET=
SUPABASE_AZURE_URL=https://login.microsoftonline.com/common/v2.0

# Plaid
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox  # sandbox, development, production

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PRICE_BASIC=
NEXT_PUBLIC_STRIPE_PRICE_PRO=
NEXT_PUBLIC_STRIPE_PRICE_ENTERPRISE=

# Fitbit OAuth
FITBIT_CLIENT_ID=
FITBIT_CLIENT_SECRET=

# Database (for NextAuth)
DATABASE_URL=postgresql://lifenavigator:password@localhost:5432/lifenavigator_dev

# NextAuth
NEXTAUTH_SECRET=your-secret-key-here

# Feature Flags
NEXT_PUBLIC_ENABLE_HEALTH_CONNECT=true
NEXT_PUBLIC_ENABLE_FINANCE=true
NEXT_PUBLIC_ENABLE_GOOGLE_INTEGRATIONS=true
NEXT_PUBLIC_ENABLE_MICROSOFT_INTEGRATIONS=true
