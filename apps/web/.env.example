# =============================================================================
# Life Navigator Frontend Configuration
# =============================================================================
# The frontend is a thin UI layer. All sensitive operations go through
# Supabase Edge Functions. Only Supabase credentials are needed here.
# =============================================================================

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Sentry (error tracking)
# DSN is hardcoded in config files — this is only needed if you want to override it
SENTRY_AUTH_TOKEN=

# Feature Flags
NEXT_PUBLIC_ENABLE_HEALTH_CONNECT=true
NEXT_PUBLIC_ENABLE_FINANCE=true
NEXT_PUBLIC_ENABLE_GOOGLE_INTEGRATIONS=true
NEXT_PUBLIC_ENABLE_MICROSOFT_INTEGRATIONS=true

# =============================================================================
# NOTE: The following secrets are stored in Supabase (not Vercel):
#   PLAID_CLIENT_ID, PLAID_SECRET, PLAID_ENV
#   GOOGLE_CLIENT_ID, GOOGLE_CLIENT_SECRET
#   INTEGRATION_ENCRYPTION_KEY
#   GEMINI_API_KEY
#   NEO4J_QUERY_API_URL, NEO4J_USERNAME, NEO4J_PASSWORD
#   QDRANT_URL, QDRANT_API_KEY
#   GRAPHRAG_WORKER_SECRET
# Set them via: supabase secrets set KEY=value
# =============================================================================
