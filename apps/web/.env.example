# =============================================================================
# Life Navigator Frontend Configuration
# =============================================================================

# App / Site URLs
# Local dev uses localhost; PRODUCTION (Vercel) values:
#   NEXT_PUBLIC_APP_URL=https://app.lifenavigator.tech     (the application)
#   NEXT_PUBLIC_SITE_URL=https://lifenavigator.tech        (marketing site)
#   NEXTAUTH_URL=https://app.lifenavigator.tech
#   APP_HOST=app.lifenavigator.tech                        (proxy host-based redirect)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
APP_HOST=app.lifenavigator.tech

# Transactional email (Resend) — domain lifenavigator.tech must be verified in Resend
RESEND_API_KEY=re_...
EMAIL_FROM=welcome@lifenavigator.tech
EMAIL_FROM_NAME=LifeNavigator

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
INTEGRATION_ENCRYPTION_KEY=

# Backend API
NEXT_PUBLIC_API_URL=http://localhost:8000

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/integrations/oauth/callback/google

# Microsoft OAuth (Outlook + Calendar)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=http://localhost:3000/api/integrations/oauth/callback/microsoft

# Plaid
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox  # sandbox, development, production

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PRICE_BASIC=
NEXT_PUBLIC_STRIPE_PRICE_PRO=
NEXT_PUBLIC_STRIPE_PRICE_ENTERPRISE=

# Fitbit OAuth
FITBIT_CLIENT_ID=
FITBIT_CLIENT_SECRET=

# Database (for NextAuth)
DATABASE_URL=postgresql://lifenavigator:password@localhost:5432/lifenavigator_dev

# NextAuth
NEXTAUTH_SECRET=your-secret-key-here

# Feature Flags
NEXT_PUBLIC_ENABLE_HEALTH_CONNECT=true
NEXT_PUBLIC_ENABLE_FINANCE=true
NEXT_PUBLIC_ENABLE_GOOGLE_INTEGRATIONS=true
NEXT_PUBLIC_ENABLE_MICROSOFT_INTEGRATIONS=true

# ── AI Model Router (Vertex AI) ──────────────────────────────────────────────
# Server-side only (NOT NEXT_PUBLIC). LLM calls run on the Fly backend via ADC — no keys on Vercel.
# VERIFY every model id in Vertex AI Model Garden before production (see lib/ai/modelRegistry.ts).
AI_PROVIDER=vertex
AI_MODEL_ROUTER_ENABLED=true
AI_VERTEX_LOCATION=us-central1
AI_DEFAULT_MODEL=gemini-3.5-flash          # VERIFY availability; else gemini-2.5-flash
AI_CHEAP_MODEL=gemini-2.5-flash-lite
AI_REASONING_MODEL=gemini-2.5-pro
# Claude via Vertex Model Garden — region-limited (often us-east5/europe-west1). Off by default.
AI_ENABLE_CLAUDE=false
AI_ENABLE_CLAUDE_OPUS=false
AI_CLAUDE_SONNET_MODEL=claude-sonnet-4-5   # VERIFY exact "@version" + region in Model Garden
AI_CLAUDE_OPUS_MODEL=claude-opus-4-1       # VERIFY exact "@version" + region in Model Garden
# AI_AUDIT_DEV_CONTENT=false                # dev-only: include a prompt preview in audit logs
