# LifeNavigator FastAPI gateway — environment template.
# Copy to `.env` for local dev. NEVER commit real values.

# --- Supabase Auth + Postgres ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
# JWT secret used by Supabase Auth (HS256). Required to verify the
# incoming Authorization header. Find at:
#   Supabase project → settings → API → JWT secret.
SUPABASE_JWT_SECRET=replace-me
# Service-role key. Used only for trusted server-side reads of
# user-graph rows; never sent to the frontend.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Gemini (Google GenAI) ---
GEMINI_API_KEY=AIza...
GEMINI_EMBEDDING_MODEL=text-embedding-004
GEMINI_GENERATION_MODEL=gemini-2.0-flash

# --- Qdrant ---
QDRANT_URL=https://xxxxx.qdrant.io:6333
QDRANT_API_KEY=...
# Personal (per-user) collection — every query MUST filter by user_id.
QDRANT_PERSONAL_COLLECTION=life_navigator
# Central / shared knowledge collection — read-only.
QDRANT_CENTRAL_COLLECTION=ln_central

# --- Neo4j ---
NEO4J_URI=https://xxxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=...
NEO4J_PERSONAL_DATABASE=neo4j
NEO4J_CENTRAL_DATABASE=central

# --- Service config ---
PORT=8080
LOG_LEVEL=info
# CORS — comma-separated list of allowed origins for the Vercel frontend.
ALLOWED_ORIGINS=https://lifenavigator.app,https://*.vercel.app,http://localhost:3000
