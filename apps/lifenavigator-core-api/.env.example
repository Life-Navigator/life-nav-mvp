# lifenavigator-core-api — environment template.
# Copy to .env for local dev. NEVER commit real secrets.
# In production these are Fly secrets (reuse the api-gateway values).

# --- Supabase (system of record + auth) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_SERVICE_ROLE_KEY=

# --- Gemini (server-side reasoning ONLY — never in the frontend) ---
GEMINI_API_KEY=
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_GENERATION_MODEL=gemini-2.5-flash

# --- Qdrant (grounding vectors) ---
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_PERSONAL_COLLECTION=life_navigator
QDRANT_CENTRAL_COLLECTION=ln_central

# --- Neo4j (grounding graph) ---
NEO4J_URI=
NEO4J_USERNAME=
NEO4J_PASSWORD=
NEO4J_PERSONAL_DATABASE=neo4j
NEO4J_CENTRAL_DATABASE=central

# --- Service ---
PORT=8080
LOG_LEVEL=info
ALLOWED_ORIGINS=https://lifenavigator.tech
