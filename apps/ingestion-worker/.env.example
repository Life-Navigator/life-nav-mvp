# LifeNavigator ingestion worker — environment template.
# Copy to `.env` for local dev. NEVER commit real values.

# --- Supabase ---
# Service-role key — required so the worker can read across users when
# claiming + completing graphrag.sync_queue jobs and reading source rows.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Gemini (Google GenAI) ---
GEMINI_API_KEY=AIza...
# Optional override; defaults to text-embedding-004.
GEMINI_EMBEDDING_MODEL=text-embedding-004

# --- Qdrant ---
QDRANT_URL=https://xxxxx.qdrant.io:6333
QDRANT_API_KEY=...
# Collection name for the personal/per-user knowledge graph.
QDRANT_PERSONAL_COLLECTION=life_navigator

# --- Neo4j ---
NEO4J_URI=https://xxxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=...
# Default database to write into.
NEO4J_PERSONAL_DATABASE=neo4j

# --- Worker behavior ---
WORKER_POLL_INTERVAL_SECONDS=5
WORKER_BATCH_SIZE=25
WORKER_MAX_RETRIES=5

# --- Logging ---
# trace | debug | info | warn | error
LOG_LEVEL=info
