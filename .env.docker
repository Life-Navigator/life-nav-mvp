# Docker Compose Environment Configuration
# This file contains environment variables for Docker containers
# Copy to .env before running docker-compose

# =============================================================================
# Application Settings
# =============================================================================
APP_ENVIRONMENT=development
APP_DEBUG=true
APP_LOG_LEVEL=INFO
APP_API_HOST=0.0.0.0
APP_API_PORT=8080

# =============================================================================
# PostgreSQL Configuration
# =============================================================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DATABASE=life_navigator_agents
POSTGRES_USER=lna_user
POSTGRES_PASSWORD=lna_dev_password_2024
POSTGRES_POOL_SIZE=10
POSTGRES_SSL_MODE=prefer

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=lna_redis_password
REDIS_DB=0
REDIS_SSL=false
REDIS_POOL_SIZE=10

# =============================================================================
# RabbitMQ Configuration
# =============================================================================
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=lna_user
RABBITMQ_PASSWORD=lna_rabbitmq_password
RABBITMQ_VHOST=/
RABBITMQ_PREFETCH_COUNT=10

# =============================================================================
# Qdrant Configuration
# =============================================================================
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=life_navigator
QDRANT_VECTOR_SIZE=384

# =============================================================================
# Neptune Configuration (LocalStack for local dev)
# =============================================================================
NEPTUNE_CLUSTER_ENDPOINT=localstack
NEPTUNE_PORT=8182
NEPTUNE_USE_IAM_AUTH=false
NEPTUNE_REGION=us-west-2

# =============================================================================
# vLLM Configuration
# =============================================================================
VLLM_INSTANCE_1=http://vllm-1:8000
VLLM_INSTANCE_2=http://vllm-2:8000
VLLM_MODEL_NAME=meta-llama/Llama-3.1-70B-Instruct
VLLM_TIMEOUT=30
VLLM_MAX_TOKENS=4096
VLLM_TEMPERATURE=0.7

# =============================================================================
# JWT Configuration
# =============================================================================
JWT_SECRET_KEY=docker-dev-secret-key-change-in-production-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# =============================================================================
# Docker Compose Profiles
# =============================================================================
# Uncomment to enable GPU-accelerated vLLM instances
# COMPOSE_PROFILES=gpu

# Uncomment to enable application container
# COMPOSE_PROFILES=app

# Enable both
# COMPOSE_PROFILES=gpu,app
