# Example Terraform Variables for Development Environment
# Copy this file to terraform.tfvars and fill in your actual values

# AWS Region
aws_region = "us-east-1"

# Container Image
# Update with your ECR repository URI after building the Docker image
container_image = "123456789.dkr.ecr.us-east-1.amazonaws.com/agent-api:latest"

# vLLM Endpoint
# Leave empty to use AWS Bedrock as fallback
vllm_endpoint = ""

# MCP Server URL
# URL of the Life Navigator app's MCP endpoint
mcp_server_url = "https://dev-app.example.com/mcp"

# Alert Emails
# List of email addresses to receive CloudWatch alerts
alert_emails = [
  "dev-team@example.com"
]
