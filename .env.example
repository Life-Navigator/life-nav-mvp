# ==============================================================================
# LIFE NAVIGATOR - ENVIRONMENT CONFIGURATION
# ==============================================================================
# Copy this file to .env and update with your actual values
# Do NOT commit .env to git (it's in .gitignore)
#
# For local development with docker-compose, use the docker-compose defaults
# For production GCP deployment, update all values appropriately
# ==============================================================================

# Environment
ENVIRONMENT=development
NODE_ENV=development
DEBUG=true
LOG_LEVEL=INFO
HOT_RELOAD=true

# ==============================================================================
# GCP Configuration (for production deployment)
# ==============================================================================
GCP_PROJECT_ID=life-navigator-dev
GCP_REGION=us-central1
GCP_ZONE=us-central1-a

# ==============================================================================
# Database - PostgreSQL
# ==============================================================================
# Local docker-compose: postgresql://lifenavigator:devpassword@localhost:5432/lifenavigator_dev
# Production GCP: Use Cloud SQL connection string
DATABASE_URL=postgresql://lifenavigator:devpassword@localhost:5432/lifenavigator_dev
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=lifenavigator_dev
POSTGRES_USER=lifenavigator
POSTGRES_PASSWORD=devpassword

# Database - Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=devpassword
NEO4J_DATABASE=neo4j

# Database - GraphDB
GRAPHDB_URL=http://localhost:7200
GRAPHDB_REPOSITORY=life-navigator
GRAPHDB_USERNAME=admin
GRAPHDB_PASSWORD=devpassword

# Cache - Redis
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# Vector Database - Qdrant
QDRANT_URL=http://localhost:6333

# ==============================================================================
# API Configuration
# ==============================================================================
API_URL=http://localhost:8000
API_VERSION=v1
NEXT_PUBLIC_API_URL=http://localhost:8000

# Service URLs
BACKEND_URL=http://localhost:8000
FINANCE_API_URL=http://localhost:8001
AGENTS_URL=http://localhost:8080
MCP_SERVER_URL=http://localhost:8090

# ==============================================================================
# Authentication & Security
# ==============================================================================
# Generate secure keys with: openssl rand -hex 32
SECRET_KEY=dev-secret-key-change-in-production-minimum-32-chars-12345678
JWT_SECRET=dev-jwt-secret-change-in-production-minimum-32-characters-abc
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ENCRYPTION_KEY=dev-encryption-key-32-bytes-change-in-production-123456

# ==============================================================================
# GraphRAG Service
# ==============================================================================
GRAPHRAG_URL=http://localhost:50051

# ==============================================================================
# AI Services - REQUIRED
# ==============================================================================
# Get your Anthropic API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-key-REQUIRED
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# AI Services - Optional
OPENAI_API_KEY=your-openai-key-optional
GOOGLE_AI_API_KEY=your-google-key-optional
VERTEX_AI_PROJECT=your-project-id
VERTEX_AI_LOCATION=us-central1
VERTEX_AI_MODEL=text-bison@002

# LLM Endpoint (for MCP Server)
LLM_ENDPOINT=http://localhost:8090/v1/chat/completions

# ==============================================================================
# Finance API - OCR Configuration
# ==============================================================================
# Enable/disable OCR engines (requires corresponding models)
ENABLE_TESSERACT=true
ENABLE_PADDLEOCR=true
ENABLE_DEEPSEEK=false  # Requires GPU - enable for production
OCR_CONFIDENCE_THRESHOLD=0.7

# ==============================================================================
# External Financial APIs (Optional for MVP)
# ==============================================================================
# Plaid - Banking integration
PLAID_CLIENT_ID=your-plaid-client-id-optional
PLAID_SECRET=your-plaid-secret-optional
PLAID_ENVIRONMENT=sandbox

# Stock Market Data
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key-optional
IEX_CLOUD_API_KEY=your-iex-cloud-key-optional
FRED_API_KEY=your-fred-api-key-optional

# Trading (Alpaca)
ALPACA_API_KEY=your-alpaca-key-optional
ALPACA_SECRET_KEY=your-alpaca-secret-optional

# Payments
STRIPE_SECRET_KEY=your-stripe-key-optional

# ==============================================================================
# Storage - GCS (for production)
# ==============================================================================
GCS_BUCKET=life-navigator-documents-dev
GCS_BUCKET_MODELS=life-navigator-ocr-models-dev
GCS_BUCKET_ONTOLOGY=life-navigator-ontology-dev

# Observability
LOG_LEVEL=INFO
SENTRY_DSN=your-sentry-dsn
SENTRY_ENVIRONMENT=development

# Feature Flags
ENABLE_GRAPHDB=true
ENABLE_NEO4J=true
ENABLE_VECTOR_SEARCH=true
ENABLE_MFA=true

# Multi-tenancy
TENANT_ISOLATION_ENABLED=true
DEFAULT_TENANT_ID=default

# HIPAA Compliance
ENABLE_AUDIT_LOGGING=true
ENABLE_ENCRYPTION_AT_REST=true
ENABLE_FIELD_LEVEL_ENCRYPTION=true

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# ==============================================================================
# CORS Configuration
# ==============================================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:19006
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:8000

# ==============================================================================
# RabbitMQ (for agents messaging - optional)
# ==============================================================================
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# ==============================================================================
# Email (Optional)
# ==============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@lifenavigator.com
ENABLE_EMAIL_NOTIFICATIONS=false
ENABLE_SMS_NOTIFICATIONS=false

# ==============================================================================
# Monitoring & Observability (Optional)
# ==============================================================================
SENTRY_DSN=your-sentry-dsn-optional
SENTRY_ENVIRONMENT=development

# ==============================================================================
# GPU Configuration (for production with OCR/ML workloads)
# ==============================================================================
ENABLE_GPU=false  # Set to true in production with GPU nodes
CUDA_VISIBLE_DEVICES=0
USE_LOCAL_EMBEDDINGS=true
