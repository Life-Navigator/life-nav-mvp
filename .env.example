# Life Navigator Agents - Environment Configuration
# Copy this file to .env and update with your actual values

# =============================================================================
# vLLM Configuration
# =============================================================================
VLLM_INSTANCE_1=http://localhost:8000
VLLM_INSTANCE_2=http://localhost:8001
VLLM_MODEL_NAME=meta-llama/Llama-4-Maverick-17B-128E
VLLM_TIMEOUT=30
VLLM_MAX_TOKENS=4096
VLLM_TEMPERATURE=0.7

# =============================================================================
# PostgreSQL Configuration
# =============================================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DATABASE=life_navigator_agents
POSTGRES_USER=lna_user
POSTGRES_PASSWORD=change-this-to-a-secure-password-min-12-chars
POSTGRES_POOL_SIZE=10
POSTGRES_SSL_MODE=prefer

# =============================================================================
# AWS Neptune Configuration
# =============================================================================
NEPTUNE_CLUSTER_ENDPOINT=neptune-cluster.us-west-2.neptune.amazonaws.com
NEPTUNE_PORT=8182
NEPTUNE_USE_IAM_AUTH=false
NEPTUNE_REGION=us-west-2

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_SSL=false
REDIS_POOL_SIZE=10

# =============================================================================
# RabbitMQ Configuration
# =============================================================================
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=lna_user
RABBITMQ_PASSWORD=change-this-to-a-secure-password
RABBITMQ_VHOST=/
RABBITMQ_PREFETCH_COUNT=10

# =============================================================================
# Qdrant Configuration
# =============================================================================
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=life_navigator
QDRANT_VECTOR_SIZE=384

# =============================================================================
# JWT Authentication Configuration
# =============================================================================
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=change-this-to-a-cryptographically-secure-random-key-at-least-32-characters
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# =============================================================================
# Application Configuration
# =============================================================================
APP_ENVIRONMENT=development
APP_DEBUG=true
APP_LOG_LEVEL=INFO
APP_API_HOST=0.0.0.0
APP_API_PORT=8080

# =============================================================================
# Notes:
# =============================================================================
#
# Development Setup:
# 1. Copy this file: cp .env.example .env
# 2. Update passwords and secrets
# 3. For local Docker: use service names as hosts (postgres, redis, rabbitmq)
# 4. For native Python: use localhost
#
# Production Setup:
# 1. Set APP_ENVIRONMENT=production
# 2. Set APP_DEBUG=false
# 3. Use strong passwords (≥12 chars)
# 4. Generate JWT_SECRET_KEY with: openssl rand -hex 32
# 5. Set POSTGRES_SSL_MODE=require
# 6. Use managed services (RDS, ElastiCache, Amazon MQ, Neptune)
#
# Security:
# - Never commit .env to version control
# - Rotate secrets regularly
# - Use environment-specific .env files
# - In production, use AWS Secrets Manager or similar
