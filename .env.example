# ================================
# LifeNavigator Environment Variables
# ================================
# Copy this file to .env.local and fill in your values
# For production, use environment-specific files: .env.production, .env.staging

# ================================
# Database Configuration
# ================================
# PostgreSQL connection string
DATABASE_URL="postgresql://username:password@localhost:5432/lifenavigator?schema=public"

# ================================
# Redis Configuration
# ================================
# Redis for caching and session management
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
# Alternative: Use Redis URL format
# REDIS_URL="redis://default:password@localhost:6379/0"

# ================================
# Authentication (NextAuth.js)
# ================================
# Required for production
NEXTAUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-here-min-32-chars

# ================================
# AI Services (Choose one provider)
# ================================
# Option 1: OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4-turbo-preview

# Option 2: Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4-turbo
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-ada-002

# ================================
# Email Service Configuration
# ================================
# SendGrid (recommended)
SENDGRID_API_KEY=SG.your-sendgrid-api-key
EMAIL_FROM=noreply@yourdomain.com

# Alternative: SMTP Configuration
EMAIL_SERVER_HOST=smtp.gmail.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=your-email@gmail.com
EMAIL_SERVER_PASSWORD=your-app-specific-password

# ================================
# File Storage
# ================================
# Option 1: Local storage (development only)
STORAGE_TYPE=local
STORAGE_PATH=./uploads

# Option 2: Azure Storage
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=youraccount;AccountKey=yourkey;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER=uploads

# Option 3: AWS S3
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-bucket-name

# ================================
# Security & Encryption
# ================================
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your-32-byte-hex-encryption-key
JWT_SECRET=your-jwt-secret-min-32-chars

# Password hashing rounds (default: 10)
BCRYPT_ROUNDS=10

# ================================
# Rate Limiting
# ================================
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_SKIP_SUCCESSFUL_REQUESTS=false
RATE_LIMIT_SKIP_FAILED_REQUESTS=false

# ================================
# Session Configuration
# ================================
SESSION_MAX_AGE=28800  # 8 hours in seconds
SESSION_UPDATE_AGE=3600  # 1 hour in seconds

# ================================
# Agent System Configuration
# ================================
# Agent API endpoint (backend service)
AGENT_API_URL=http://localhost:8000
# Agent request timeout in milliseconds (default: 30000 = 30 seconds)
AGENT_TIMEOUT=30000
# Number of retry attempts for failed agent requests (default: 3)
AGENT_RETRIES=3
# Base delay between retries in milliseconds (default: 1000 = 1 second)
# Uses exponential backoff: delay = AGENT_RETRY_DELAY * (2 ^ attempt)
AGENT_RETRY_DELAY=1000
# Environment designation for agent requests
AGENT_ENVIRONMENT=development

# WebSocket Configuration (for real-time agent communication)
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# ================================
# API Configuration
# ================================
NEXT_PUBLIC_API_URL=http://localhost:3000/api
API_KEY_SALT=your-api-key-salt

# Admin API Keys (comma-separated)
ADMIN_API_KEYS=

# ================================
# Monitoring & Analytics
# ================================
# Google Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Application Insights (Azure)
APPLICATIONINSIGHTS_CONNECTION_STRING=

# Sentry Error Tracking
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_SENTRY_DSN=

# ================================
# Feature Flags
# ================================
ENABLE_MULTI_AGENT_CHAT=false
ENABLE_GRAPHRAG=false
ENABLE_RISK_ASSESSMENT=true
ENABLE_GOAL_PLANNING=true
ENABLE_AI_INSIGHTS=true
ENABLE_DOCUMENT_UPLOAD=true
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_MFA=true
ENABLE_SOCIAL_AUTH=false

# ================================
# Third-party Integrations
# ================================
# Plaid (Financial Data)
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox  # sandbox, development, or production

# Google OAuth (Gmail, Calendar)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/oauth/google/callback

# Microsoft OAuth (Outlook, Calendar)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:3000/api/oauth/microsoft/callback
MICROSOFT_TENANT_ID=common

# LinkedIn OAuth
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:3000/api/oauth/linkedin/callback

# Twitter OAuth 2.0
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_BEARER_TOKEN=
TWITTER_REDIRECT_URI=http://localhost:3000/api/oauth/twitter/callback

# Instagram Basic Display API
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
INSTAGRAM_REDIRECT_URI=http://localhost:3000/api/oauth/instagram/callback

# TikTok OAuth
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:3000/api/oauth/tiktok/callback

# Stripe (Payments)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ================================
# Development Settings
# ================================
NODE_ENV=development
NEXT_TELEMETRY_DISABLED=1
LOG_LEVEL=debug  # debug, info, warn, error

# ================================
# Deployment Configuration
# ================================
# Vercel
VERCEL_URL=

# Azure
WEBSITE_SITE_NAME=
WEBSITE_RESOURCE_GROUP=

# Docker
DOCKER_REGISTRY=
DOCKER_IMAGE_TAG=latest

# ================================
# Compliance & Legal
# ================================
# Data retention (days)
DATA_RETENTION_DAYS=2555  # 7 years for HIPAA
AUDIT_LOG_RETENTION_DAYS=2190  # 6 years

# Privacy settings
ENABLE_COOKIE_CONSENT=true
ENABLE_GDPR_FEATURES=false
ENABLE_CCPA_FEATURES=false

# ================================
# Backup Configuration
# ================================
BACKUP_ENABLED=false
BACKUP_SCHEDULE="0 2 * * *"  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30
BACKUP_STORAGE_PATH=

# ================================
# CORS Configuration
# ================================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization

# ================================
# GraphRAG Configuration (if enabled)
# ================================
GRAPHRAG_DATABASE_NAME=lifenavigator-graph
GRAPHRAG_CONTAINER_NAME=user-knowledge
GRAPHRAG_GRAPH_CONTAINER=knowledge-graph

# Azure Cosmos DB (for GraphRAG)
AZURE_COSMOSDB_ENDPOINT=
AZURE_COSMOSDB_KEY=

# Azure Cognitive Search (for GraphRAG)
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_API_KEY=
AZURE_SEARCH_INDEX_NAME=lifenavigator-knowledge

# ================================
# Notes
# ================================
# 1. Never commit .env files with real values to version control
# 2. Use strong, unique passwords and secrets
# 3. Rotate secrets regularly in production
# 4. Use environment-specific configurations for staging/production
# 5. Enable only the features you need for security
# 6. Configure monitoring before going to production