# =============================================================================
# Life Navigator — Environment Variables
# Copy to `.env.local` and fill in values. NEVER commit with real credentials.
# =============================================================================

# Public URLs (production)
NEXT_PUBLIC_SITE_URL=https://lifenavigator.tech        # marketing site (apex)
NEXT_PUBLIC_APP_URL=https://app.lifenavigator.tech     # the application
NEXTAUTH_URL=https://app.lifenavigator.tech
APP_HOST=app.lifenavigator.tech                         # proxy: app-subdomain root → /auth/login

# Transactional email (Resend) — verify lifenavigator.tech in Resend first
RESEND_API_KEY=re_...
EMAIL_FROM=welcome@lifenavigator.tech
EMAIL_FROM_NAME=LifeNavigator

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Encryption (required — column-level encryption for sensitive data)
INTEGRATION_ENCRYPTION_KEY=generate-a-64-char-hex-string

# Google OAuth (required for Gmail + Calendar)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Microsoft OAuth (required for Outlook + Calendar)
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret

# Stripe (billing)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Plaid (bank account connections)
PLAID_CLIENT_ID=your-plaid-client-id
PLAID_SECRET=your-plaid-secret
PLAID_ENV=sandbox

# GraphRAG Worker (Next.js server → Edge Function auth)
GRAPHRAG_WORKER_SECRET=generate-a-random-secret

# =============================================================================
# Supabase Edge Function Secrets
# Set via: supabase secrets set KEY=VALUE
# These are NEVER stored in .env — only in Supabase Vault.
# =============================================================================
# GEMINI_API_KEY=AIza...
# NEO4J_HTTP_URL=https://xxxxx.databases.neo4j.io
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=...
# QDRANT_URL=https://xxxxx.qdrant.io:6333
# QDRANT_API_KEY=...
# QDRANT_COLLECTION=life_navigator
# GRAPHRAG_WORKER_SECRET=<same-as-above>
