# GCP Configuration
GCP_PROJECT_ID=your-project-id
GCP_REGION=us-central1
GCP_ZONE=us-central1-a

# Database - PostgreSQL
DATABASE_URL=postgresql://postgres:localdev@localhost:5432/lifenavigator
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=lifenavigator
DATABASE_USER=postgres
DATABASE_PASSWORD=localdev

# Database - Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=localdev
NEO4J_DATABASE=neo4j

# Database - GraphDB
GRAPHDB_URL=http://localhost:7200
GRAPHDB_REPOSITORY=lifenavigator
GRAPHDB_USERNAME=admin
GRAPHDB_PASSWORD=localdev

# Cache - Redis
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# API Configuration
API_URL=http://localhost:8000
API_VERSION=v1
NEXT_PUBLIC_API_URL=http://localhost:8000

# Authentication & Security
JWT_SECRET=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ENCRYPTION_KEY=your-encryption-key-32-bytes

# AI Services - Anthropic
ANTHROPIC_API_KEY=your-anthropic-key
ANTHROPIC_MODEL=claude-3-opus-20240229

# AI Services - Google
GOOGLE_AI_API_KEY=your-google-key
VERTEX_AI_PROJECT=your-project-id
VERTEX_AI_LOCATION=us-central1
VERTEX_AI_MODEL=text-bison@002

# AI Services - OpenAI (optional)
OPENAI_API_KEY=your-openai-key

# Storage - GCS
GCS_BUCKET=life-navigator-documents
GCS_BUCKET_MODELS=life-navigator-models
GCS_BUCKET_ONTOLOGY=life-navigator-ontology

# Observability
LOG_LEVEL=INFO
SENTRY_DSN=your-sentry-dsn
SENTRY_ENVIRONMENT=development

# Feature Flags
ENABLE_GRAPHDB=true
ENABLE_NEO4J=true
ENABLE_VECTOR_SEARCH=true
ENABLE_MFA=true

# Multi-tenancy
TENANT_ISOLATION_ENABLED=true
DEFAULT_TENANT_ID=default

# HIPAA Compliance
ENABLE_AUDIT_LOGGING=true
ENABLE_ENCRYPTION_AT_REST=true
ENABLE_FIELD_LEVEL_ENCRYPTION=true

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:19006

# Email (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@lifenavigator.com

# Development
NODE_ENV=development
DEBUG=true
HOT_RELOAD=true
