# ============================================================================
# Life Navigator Environment Variables
# ============================================================================
# IMPORTANT: Copy this file to `.env` and fill in actual values
# NEVER commit the `.env` file with real credentials!
#
# Generate secure credentials using:
#   openssl rand -hex 32    # For SECRET_KEY
#   openssl rand -base64 24 # For passwords
# ============================================================================

# ----------------------------------------------------------------------------
# Database Configuration
# ----------------------------------------------------------------------------
POSTGRES_USER=lifenavigator
POSTGRES_PASSWORD=        # REQUIRED: Set a strong password (min 20 chars)
POSTGRES_DB=lifenavigator_dev

# ----------------------------------------------------------------------------
# Neo4j Knowledge Graph
# ----------------------------------------------------------------------------
NEO4J_PASSWORD=           # REQUIRED: Set a strong password (min 12 chars)

# ----------------------------------------------------------------------------
# Application Security
# ----------------------------------------------------------------------------
SECRET_KEY=               # REQUIRED: Set a 64-character hex string (openssl rand -hex 32)

# ----------------------------------------------------------------------------
# External API Keys (Optional - Required for specific features)
# ----------------------------------------------------------------------------
# AI Services
ANTHROPIC_API_KEY=        # Optional: For Claude AI integration
OPENAI_API_KEY=           # Optional: For OpenAI integration

# Financial Services
PLAID_CLIENT_ID=          # Optional: For Plaid bank connection
PLAID_SECRET=             # Optional: For Plaid bank connection
PLAID_ENVIRONMENT=sandbox # Options: sandbox, development, production

# Stock Market Data
ALPHA_VANTAGE_API_KEY=    # Optional: For stock market data

# ----------------------------------------------------------------------------
# Message Queue (Optional - for distributed systems)
# ----------------------------------------------------------------------------
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# ============================================================================
# SECURITY NOTES
# ============================================================================
# 1. Generate strong, unique credentials for each environment
# 2. Use a password manager (1Password, LastPass) to securely store credentials
# 3. In production, use GCP Secret Manager or similar service
# 4. Rotate credentials every 90 days
# 5. Never commit this file with actual values
# 6. Each team member should have their own local .env file
# ============================================================================
