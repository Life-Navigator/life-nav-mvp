# Life Navigator API - Environment Variables

# Application
APP_NAME=Life Navigator API
APP_VERSION=0.1.0
API_V1_PREFIX=/api/v1
DEBUG=false

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/lifenavigator
DB_ECHO=false

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j

# GraphDB
GRAPHDB_URL=http://localhost:7200
GRAPHDB_REPOSITORY=lifenavigator

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379

# Security
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS (comma-separated list)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:19006

# AI Services
ANTHROPIC_API_KEY=
VERTEX_AI_PROJECT=
VERTEX_AI_LOCATION=us-central1

# GCP
GCP_PROJECT_ID=
GCP_REGION=us-central1

# Multi-tenancy
TENANT_ISOLATION_ENABLED=true

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
