# =============================================================================
# Supabase Edge Function Secrets — Production Template
# =============================================================================
# Copy to `.env.supabase.prod` and fill in values.
# Deploy with: supabase secrets set --env-file .env.supabase.prod
# NEVER commit the filled-in file.
# =============================================================================

# --- Google AI / Gemini ---
GEMINI_API_KEY=

# --- Neo4j Aura (Knowledge Graph) ---
# Bolt URI for Python driver (neo4j+s:// protocol)
NEO4J_URI=neo4j+s://xxxxx.databases.neo4j.io
# HTTPS Query API URL for Edge Functions (port 443, not 7473)
NEO4J_QUERY_API_URL=https://xxxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=

# --- Qdrant Cloud (Vector Store) ---
QDRANT_URL=https://xxxxx.cloud.qdrant.io:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=life_navigator

# --- Service-to-Service Auth ---
# Shared secret between Next.js app, Edge Functions, and Python pipeline
# Generate with: openssl rand -hex 32
GRAPHRAG_WORKER_SECRET=

# --- Integration Encryption ---
# Column-level encryption key for sensitive data (OAuth tokens, account numbers)
# Generate with: openssl rand -hex 32
INTEGRATION_ENCRYPTION_KEY=

# --- Google OAuth (Gmail + Calendar integration) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Plaid (Bank connections) ---
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# --- GraphRAG Pipeline URL (Vercel Python Functions) ---
# Set this after deploying the graphrag-pipeline Vercel app
# GRAPHRAG_PIPELINE_URL=https://your-graphrag-pipeline.vercel.app
